---

<html lang="sv">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>La Copa del Mundo 2026</title>
		<style is:global>
			@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Inter:wght@400;500;600&display=swap');

			:root {
				--bg: #0a0e14;
				--card: #111825;
				--text: #f0f0f0;
				--muted: #8a9ab5;
				--yellow: #fecc02;
				--celeste: #75aadb;
			}

			* { margin: 0; padding: 0; box-sizing: border-box; }
			html { scroll-behavior: smooth; }

			body {
				font-family: 'Inter', system-ui, sans-serif;
				background: var(--bg);
				color: var(--text);
				line-height: 1.6;
			}

			h1, h2, h3 {
				font-family: 'Oswald', sans-serif;
				text-transform: uppercase;
			}

			/* ---- HERO ---- */
			.hero {
				position: relative;
				height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				overflow: hidden;
			}

			.hero-bg {
				position: absolute;
				inset: 0;
				background: url('/forlan.jpg') center center / cover no-repeat;
				filter: brightness(0.3) saturate(1.2);
			}

			.hero-overlay {
				position: absolute;
				inset: 0;
				background: linear-gradient(
					to bottom,
					rgba(10, 14, 20, 0.2) 0%,
					rgba(10, 14, 20, 0.1) 50%,
					rgba(10, 14, 20, 0.9) 90%,
					rgba(10, 14, 20, 1) 100%
				);
			}

			.hero-content {
				position: relative;
				z-index: 1;
				padding: 2rem;
			}

			.hero h1 {
				font-size: clamp(2.5rem, 8vw, 5.5rem);
				font-weight: 700;
				line-height: 1;
				letter-spacing: 0.03em;
				margin-bottom: 1rem;
			}

			.hero .sub {
				font-family: 'Oswald', sans-serif;
				font-size: clamp(1rem, 2.5vw, 1.4rem);
				text-transform: uppercase;
				letter-spacing: 0.15em;
				color: var(--muted);
				margin-bottom: 3rem;
				font-style: italic;
			}

			.cta {
				display: inline-block;
				padding: 1rem 2.5rem;
				background: var(--yellow);
				color: var(--bg);
				font-family: 'Oswald', sans-serif;
				font-size: 1.15rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				text-decoration: none;
				transition: all 0.2s;
			}

			.cta:hover {
				background: #fff;
				transform: translateY(-2px);
				box-shadow: 0 8px 30px rgba(245, 197, 24, 0.2);
			}

			/* ---- SECTIONS ---- */
			.section {
				padding: 5rem 2rem;
				max-width: 800px;
				margin: 0 auto;
			}

			.section h2 {
				font-size: 2rem;
				margin-bottom: 0.5rem;
				color: var(--yellow);
			}

			.section-intro {
				color: var(--muted);
				margin-bottom: 2rem;
			}

			/* ---- STEPS ---- */
			.steps { display: grid; gap: 1.25rem; }

			.step {
				display: flex;
				gap: 1.5rem;
				align-items: flex-start;
				background: var(--card);
				padding: 1.75rem;
				border-left: 3px solid var(--celeste);
			}

			.step-num {
				font-family: 'Oswald', sans-serif;
				font-size: 2.2rem;
				font-weight: 700;
				color: var(--celeste);
				line-height: 1;
				flex-shrink: 0;
				width: 2rem;
				text-align: center;
			}

			.step h3 { font-size: 1.1rem; margin-bottom: 0.3rem; }
			.step p { color: var(--muted); }
			.step strong { color: var(--text); }

			/* ---- SWISH ---- */
			.swish-box {
				background: var(--card);
				padding: 2.5rem 2rem;
				text-align: center;
			}

			.swish-box h3 {
				font-size: 1.4rem;
				margin-bottom: 0.5rem;
			}

			.swish-box .amount {
				font-family: 'Oswald', sans-serif;
				font-size: 2.5rem;
				font-weight: 700;
				color: var(--yellow);
				margin-bottom: 1.5rem;
			}

			.swish-qr {
				background: #fff;
				display: inline-block;
				padding: 1rem;
				border-radius: 8px;
				margin-bottom: 1rem;
			}

			.swish-qr img {
				display: block;
				width: 200px;
				height: 200px;
			}

			.swish-btn {
				display: block;
				margin: 0 auto 1.5rem;
				padding: 1rem 2rem;
				background: #4DAB3D;
				color: #fff;
				font-family: 'Oswald', sans-serif;
				font-size: 1.15rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.03em;
				text-decoration: none;
				border-radius: 40px;
				transition: all 0.2s;
				width: fit-content;
			}

			.swish-btn:hover {
				background: #3d9a2e;
				transform: translateY(-2px);
				box-shadow: 0 6px 20px rgba(77, 171, 61, 0.3);
			}

			.swish-or {
				color: var(--muted);
				font-size: 0.85rem;
				margin-bottom: 1rem;
			}

			.swish-hint {
				color: var(--muted);
				font-size: 0.85rem;
				margin-top: 0.5rem;
			}

			/* ---- PRIZES ---- */
			.prizes {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.25rem;
				margin-bottom: 1.25rem;
			}

			.prize {
				background: var(--card);
				padding: 1.75rem 1.25rem;
				text-align: center;
			}

			.prize-place {
				font-family: 'Oswald', sans-serif;
				font-size: 1.3rem;
				font-weight: 700;
				margin-bottom: 0.2rem;
			}

			.prize:nth-child(1) .prize-place { color: var(--yellow); }
			.prize:nth-child(2) .prize-place { color: var(--celeste); }
			.prize:nth-child(3) .prize-place { color: #cd7f32; }

			.prize:nth-child(1) { border-top: 3px solid var(--yellow); }
			.prize:nth-child(2) { border-top: 3px solid var(--celeste); }
			.prize:nth-child(3) { border-top: 3px solid #cd7f32; }

			.prize-pct {
				font-family: 'Oswald', sans-serif;
				font-size: 2.8rem;
				font-weight: 700;
				line-height: 1;
			}

			.prize-label { color: var(--muted); font-size: 0.85rem; }

			.prize-example {
				background: var(--card);
				padding: 1.1rem;
				color: var(--muted);
				text-align: center;
				font-size: 0.9rem;
			}

			.prize-example strong { color: var(--text); }

			/* ---- PARTICIPANTS ---- */
			.participants-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
				gap: 0.6rem;
			}

			.participant {
				background: var(--card);
				padding: 0.8rem 1rem;
				display: flex;
				align-items: center;
				gap: 0.7rem;
				font-weight: 500;
			}

			.participant .num {
				font-family: 'Oswald', sans-serif;
				color: var(--celeste);
				font-weight: 600;
			}

			.participant.empty {
				opacity: 0.2;
				border: 1px dashed var(--muted);
				background: transparent;
			}

			/* ---- MAIN TABS ---- */
			.main-tabs {
				display: flex;
				gap: 0;
				margin-bottom: 24px;
				border-bottom: 2px solid rgba(255,255,255,0.06);
			}

			.main-tab {
				font-family: 'Oswald', sans-serif;
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				padding: 12px 24px;
				background: none;
				color: var(--muted);
				border: none;
				cursor: pointer;
				position: relative;
				transition: color 0.2s;
			}

			.main-tab:hover { color: var(--text); }

			.main-tab.active {
				color: var(--yellow);
			}

			.main-tab.active::after {
				content: '';
				position: absolute;
				bottom: -2px;
				left: 0;
				right: 0;
				height: 2px;
				background: var(--yellow);
			}

			.main-tab-content {
				display: none;
			}

			.main-tab-content.active {
				display: block;
			}

			/* ---- TEAM PANEL TABS ---- */
			.tp-tabs {
				display: flex;
				gap: 0;
				border-bottom: 1px solid rgba(255,255,255,0.06);
				margin: 0 -24px;
				padding: 0 24px;
			}

			.tp-tab {
				font-family: 'Oswald', sans-serif;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				padding: 10px 14px;
				background: none;
				color: var(--muted);
				border: none;
				cursor: pointer;
				position: relative;
				transition: color 0.2s;
				white-space: nowrap;
			}

			.tp-tab:hover { color: var(--text); }

			.tp-tab.active {
				color: var(--celeste);
			}

			.tp-tab.active::after {
				content: '';
				position: absolute;
				bottom: -1px;
				left: 0;
				right: 0;
				height: 1px;
				background: var(--celeste);
			}

			.tp-tab-content {
				display: none;
			}

			.tp-tab-content.active {
				display: block;
			}

			/* ---- LEADERBOARD ---- */
			.section-wide {
				max-width: 1200px;
			}

			.leaderboard-layout {
				display: grid;
				grid-template-columns: 1.1fr 1fr;
				gap: 32px;
				align-items: start;
			}

			.leaderboard-loading {
				background: var(--card);
				border-radius: 4px;
				padding: 64px 24px;
				text-align: center;
				color: var(--muted);
				border: 1px solid rgba(255,255,255,0.04);
			}

			/* Leaderboard rows — no table, div-based for full control */
			.lb-header {
				display: grid;
				grid-template-columns: 48px 1fr 80px;
				padding: 0 16px 12px;
				font-family: 'Oswald', sans-serif;
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--muted);
				border-bottom: 1px solid rgba(255,255,255,0.06);
				margin-bottom: 4px;
			}

			.lb-header span:last-child { text-align: right; }

			.lb-row {
				display: grid;
				grid-template-columns: 48px 1fr 80px;
				align-items: center;
				margin-bottom: 2px;
				cursor: pointer;
				border-radius: 4px;
				overflow: hidden;
				background: var(--card);
				transition: transform 0.15s ease, background 0.2s ease;
			}

			.lb-row:hover {
				transform: scale(1.01);
				background: #172033;
			}

			.lb-row.selected {
				background: #172033;
				border-left: 3px solid var(--yellow);
			}

			.lb-pos {
				font-family: 'Oswald', sans-serif;
				font-size: 1.3rem;
				font-weight: 700;
				text-align: center;
				padding: 16px 0;
				color: var(--muted);
			}

			.lb-row.top1 .lb-pos {
				color: var(--bg);
				background: var(--yellow);
				font-size: 1.4rem;
			}

			.lb-row.top2 .lb-pos {
				color: var(--bg);
				background: var(--celeste);
			}

			.lb-row.top3 .lb-pos {
				color: var(--bg);
				background: #cd7f32;
			}

			.lb-team {
				padding: 12px 16px;
			}

			.lb-team-name {
				font-weight: 600;
				font-size: 0.95rem;
				transition: color 0.15s;
				line-height: 1.3;
			}

			.lb-row:hover .lb-team-name,
			.lb-row.selected .lb-team-name {
				color: var(--yellow);
			}

			.lb-manager {
				font-size: 0.75rem;
				color: var(--muted);
				margin-top: 1px;
			}

			.lb-score {
				text-align: right;
				padding: 12px 16px;
				font-family: 'Oswald', sans-serif;
				font-size: 1.15rem;
				font-weight: 600;
			}

			.lb-score.positive { color: #22c55e; }
			.lb-score.zero { color: var(--muted); }

			.leaderboard-info {
				margin-top: 16px;
				font-size: 0.7rem;
				color: var(--muted);
				opacity: 0.4;
				text-align: right;
				font-family: 'Oswald', sans-serif;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.leaderboard-pages {
				display: flex;
				justify-content: center;
				gap: 6px;
				margin-top: 20px;
			}

			.leaderboard-pages button {
				font-family: 'Oswald', sans-serif;
				font-size: 0.9rem;
				padding: 6px 14px;
				background: transparent;
				color: var(--muted);
				border: 1px solid rgba(255,255,255,0.08);
				border-radius: 4px;
				cursor: pointer;
				transition: all 0.15s ease;
			}

			.leaderboard-pages button:hover {
				color: var(--text);
				border-color: var(--celeste);
			}

			.leaderboard-pages button.active {
				color: var(--bg);
				background: var(--yellow);
				border-color: var(--yellow);
				font-weight: 700;
			}

			/* ---- TEAM PANEL ---- */
			.team-panel {
				position: sticky;
				top: 24px;
				background: linear-gradient(165deg, #111825 0%, #0d1320 100%);
				border: 1px solid rgba(255,255,255,0.05);
				border-radius: 4px;
				overflow: hidden;
			}

			.team-panel-empty {
				text-align: center;
				color: var(--muted);
				padding: 64px 24px;
				font-size: 0.85rem;
				line-height: 1.7;
			}

			.team-panel-empty .arrow {
				font-size: 1.8rem;
				margin-bottom: 8px;
				display: block;
				opacity: 0.3;
			}

			.tp-header {
				padding: 24px 24px 20px;
				border-bottom: 1px solid rgba(255,255,255,0.06);
				background: linear-gradient(135deg, rgba(254,204,2,0.04) 0%, transparent 60%);
			}

			.tp-header h3 {
				font-size: 1.5rem;
				margin-bottom: 2px;
				letter-spacing: 0.02em;
			}

			.tp-header .tp-manager {
				color: var(--muted);
				font-size: 0.8rem;
				font-family: 'Oswald', sans-serif;
				letter-spacing: 0.04em;
			}

			.tp-section {
				padding: 20px 24px;
			}

			.tp-section + .tp-section {
				border-top: 1px solid rgba(255,255,255,0.04);
			}

			.tp-section-title {
				font-family: 'Oswald', sans-serif;
				font-size: 0.65rem;
				text-transform: uppercase;
				letter-spacing: 0.16em;
				color: var(--celeste);
				margin-bottom: 12px;
			}

			.tp-player {
				display: grid;
				grid-template-columns: auto 1fr auto;
				gap: 10px;
				align-items: center;
				padding: 8px 0;
				font-size: 0.9rem;
				border-bottom: 1px solid rgba(255,255,255,0.03);
			}

			.tp-player:last-child { border-bottom: none; }

			.tp-pos-badge {
				font-family: 'Oswald', sans-serif;
				font-size: 0.6rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				padding: 3px 6px;
				border-radius: 3px;
				text-align: center;
				min-width: 36px;
				color: var(--text);
				background: rgba(255,255,255,0.06);
			}

			.tp-pos-badge.mv { background: rgba(117,170,219,0.2); color: var(--celeste); }
			.tp-pos-badge.anf { background: rgba(254,204,2,0.15); color: var(--yellow); }

			.tp-player-name {
				font-weight: 500;
			}

			.tp-player .captain {
				color: var(--bg);
				background: var(--yellow);
				font-size: 0.6rem;
				font-weight: 700;
				font-family: 'Oswald', sans-serif;
				margin-left: 6px;
				padding: 2px 5px;
				border-radius: 3px;
				vertical-align: 1px;
			}

			.tp-player-club {
				color: var(--muted);
				font-size: 0.75rem;
				font-family: 'Oswald', sans-serif;
				letter-spacing: 0.04em;
				text-align: right;
			}

			.tp-round {
				display: grid;
				grid-template-columns: auto 1fr auto;
				gap: 12px;
				align-items: center;
				padding: 6px 0;
			}

			.tp-round-num {
				font-family: 'Oswald', sans-serif;
				font-size: 0.8rem;
				color: var(--muted);
				min-width: 20px;
			}

			.tp-round-bar {
				height: 6px;
				border-radius: 3px;
				background: rgba(255,255,255,0.04);
				overflow: hidden;
			}

			.tp-round-bar-fill {
				height: 100%;
				border-radius: 3px;
				transition: width 0.4s ease;
			}

			.tp-round-bar-fill.pos { background: linear-gradient(90deg, #22c55e, #4ade80); }
			.tp-round-bar-fill.neg { background: linear-gradient(90deg, #ef4444, #f87171); }

			.tp-round-val {
				font-family: 'Oswald', sans-serif;
				font-size: 0.85rem;
				font-weight: 600;
				min-width: 60px;
				text-align: right;
			}

			.tp-round-val.pos { color: #22c55e; }
			.tp-round-val.neg { color: #ef4444; }

			.tp-loading {
				text-align: center;
				color: var(--muted);
				padding: 64px 24px;
				font-size: 0.85rem;
			}

			/* ---- STAT HIGHLIGHTS ---- */
			.stat-cards {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
				gap: 8px;
				margin-bottom: 32px;
			}

			.stat-card {
				background: var(--card);
				border-radius: 4px;
				padding: 16px;
				border-left: 3px solid var(--celeste);
			}

			.stat-card:nth-child(1) { border-left-color: var(--yellow); }
			.stat-card:nth-child(2) { border-left-color: #ef4444; }
			.stat-card:nth-child(3) { border-left-color: var(--celeste); }
			.stat-card:nth-child(4) { border-left-color: #22c55e; }
			.stat-card:nth-child(5) { border-left-color: #a855f7; }

			.stat-card-label {
				font-family: 'Oswald', sans-serif;
				font-size: 0.6rem;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: var(--muted);
				margin-bottom: 6px;
			}

			.stat-card-team {
				font-weight: 600;
				font-size: 0.95rem;
				margin-bottom: 2px;
			}

			.stat-card-detail {
				font-size: 0.8rem;
				color: var(--muted);
			}

			/* ---- HEAD TO HEAD ---- */
			.h2h-bar {
				margin-bottom: 24px;
			}

			.h2h-select {
				display: flex;
				gap: 12px;
				align-items: center;
				margin-bottom: 16px;
				flex-wrap: wrap;
			}

			.h2h-select select {
				font-family: 'Inter', sans-serif;
				font-size: 0.9rem;
				padding: 8px 12px;
				background: var(--card);
				color: var(--text);
				border: 1px solid rgba(255,255,255,0.08);
				border-radius: 4px;
				flex: 1;
				min-width: 140px;
			}

			.h2h-select .vs {
				font-family: 'Oswald', sans-serif;
				color: var(--muted);
				font-size: 0.85rem;
			}

			.h2h-rounds {
				display: flex;
				flex-direction: column;
				gap: 4px;
			}

			.h2h-round {
				display: grid;
				grid-template-columns: 80px 1fr 40px 1fr 80px;
				align-items: center;
				gap: 4px;
				font-size: 0.8rem;
			}

			.h2h-round-label {
				font-family: 'Oswald', sans-serif;
				color: var(--muted);
				font-size: 0.75rem;
				text-align: center;
			}

			.h2h-val {
				font-family: 'Oswald', sans-serif;
				font-weight: 600;
				font-size: 0.85rem;
			}

			.h2h-val.left { text-align: right; }
			.h2h-val.right { text-align: left; }
			.h2h-val.win { color: #22c55e; }
			.h2h-val.lose { color: var(--muted); }

			.h2h-bar-track {
				height: 8px;
				border-radius: 4px;
				overflow: hidden;
				background: rgba(255,255,255,0.04);
			}

			.h2h-bar-fill {
				height: 100%;
				border-radius: 4px;
			}

			.h2h-bar-fill.left { background: var(--yellow); float: right; }
			.h2h-bar-fill.right { background: var(--celeste); }

			.h2h-summary {
				display: flex;
				justify-content: space-between;
				margin-top: 12px;
				padding-top: 12px;
				border-top: 1px solid rgba(255,255,255,0.06);
				font-family: 'Oswald', sans-serif;
				font-size: 0.9rem;
			}

			.h2h-summary .total { font-weight: 700; font-size: 1.1rem; }
			.h2h-summary .wins { color: var(--muted); font-size: 0.8rem; }

			/* ---- LINE CHART ---- */
			.line-chart-wrap {
				margin-top: 8px;
				margin-bottom: 8px;
			}

			.line-chart-wrap svg {
				width: 100%;
				height: auto;
				display: block;
			}

			.line-chart-wrap .chart-line {
				fill: none;
				stroke-width: 2.5;
				stroke-linecap: round;
				stroke-linejoin: round;
			}

			.line-chart-wrap .chart-dot {
				stroke-width: 2;
			}

			.line-chart-wrap .chart-area {
				opacity: 0.08;
			}

			.line-chart-wrap .chart-grid {
				stroke: rgba(255,255,255,0.04);
				stroke-width: 1;
			}

			.line-chart-wrap .chart-label {
				fill: var(--muted);
				font-family: 'Oswald', sans-serif;
				font-size: 9px;
			}

			.chart-legend {
				display: flex;
				gap: 16px;
				justify-content: center;
				margin-top: 8px;
				font-size: 0.75rem;
				color: var(--muted);
			}

			.chart-legend span::before {
				content: '';
				display: inline-block;
				width: 12px;
				height: 3px;
				border-radius: 2px;
				margin-right: 6px;
				vertical-align: middle;
			}

			.chart-legend .leg-a::before { background: var(--yellow); }
			.chart-legend .leg-b::before { background: var(--celeste); }
			.chart-legend .leg-single::before { background: var(--yellow); }

			/* ---- TRADES ---- */
			.tp-trade-group {
				margin-bottom: 4px;
			}

			.tp-trade-group:last-child { margin-bottom: 0; }

			.tp-trade-round-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 10px 12px;
				background: rgba(255,255,255,0.03);
				border-radius: 4px;
				font-family: 'Oswald', sans-serif;
				font-size: 0.85rem;
				font-weight: 600;
				cursor: pointer;
				transition: background 0.15s;
				user-select: none;
			}

			.tp-trade-round-header:hover {
				background: rgba(255,255,255,0.06);
			}

			.tp-trade-round-header .chevron {
				font-size: 0.7rem;
				transition: transform 0.2s;
				color: var(--muted);
				margin-right: 6px;
			}

			.tp-trade-group.open .chevron {
				transform: rotate(90deg);
			}

			.tp-trade-list {
				display: none;
				padding: 4px 0 8px;
			}

			.tp-trade-group.open .tp-trade-list {
				display: block;
			}

			.tp-trade-count {
				font-size: 0.7rem;
				font-weight: 400;
				color: var(--muted);
				letter-spacing: 0.04em;
			}

			.tp-trade {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 5px 12px;
				font-size: 0.85rem;
			}

			.tp-trade-type {
				font-family: 'Oswald', sans-serif;
				font-size: 0.6rem;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				padding: 2px 6px;
				border-radius: 3px;
				margin-right: 8px;
				display: inline-block;
				min-width: 24px;
				text-align: center;
			}

			.tp-trade-type.buy { background: rgba(34,197,94,0.15); color: #22c55e; }
			.tp-trade-type.sell { background: rgba(239,68,68,0.15); color: #ef4444; }

			.tp-trade-summary {
				font-family: 'Oswald', sans-serif;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--muted);
				margin-bottom: 12px;
				padding-bottom: 8px;
				border-bottom: 1px solid rgba(255,255,255,0.04);
			}

			.tp-trade-empty-round {
				opacity: 0.4;
				cursor: default;
			}

			@media (max-width: 768px) {
				.leaderboard-layout { grid-template-columns: 1fr; }
				.section-wide { max-width: 800px; }
				.lb-row:hover { transform: none; }
				.h2h-round { grid-template-columns: 60px 1fr 30px 1fr 60px; font-size: 0.7rem; }
				.main-tab { padding: 10px 16px; font-size: 0.9rem; }
				.tp-tab { padding: 8px 10px; font-size: 0.7rem; }
				.team-panel-empty .arrow { display: none; }
				.team-panel-empty { padding: 32px 16px; }
			}

			/* ---- TIKTOKS ---- */
			.tiktoks {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 1.5rem;
				justify-items: center;
			}

			/* ---- PHOTO BREAK ---- */
			.photo-break {
				position: relative;
				height: 60vh;
				min-height: 350px;
				overflow: hidden;
			}

			.photo-break-bg {
				position: absolute;
				inset: 0;
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
				background-attachment: fixed;
				filter: brightness(0.4) saturate(1.2);
			}

			.photo-break-overlay {
				position: absolute;
				inset: 0;
				background: linear-gradient(
					to bottom,
					rgba(10, 14, 20, 1) 0%,
					rgba(10, 14, 20, 0) 15%,
					rgba(10, 14, 20, 0) 85%,
					rgba(10, 14, 20, 1) 100%
				);
			}

			@media (max-width: 768px) {
				.photo-break-bg {
					background-attachment: scroll;
				}
				.photo-break { height: 40vh; min-height: 250px; }
			}

			/* ---- DIVIDER ---- */
			.divider {
				max-width: 800px;
				margin: 0 auto;
				border: none;
				border-top: 1px solid rgba(255,255,255,0.05);
			}

			/* ---- FOOTER ---- */
			footer {
				text-align: center;
				padding: 3rem 2rem;
				border-top: 1px solid rgba(255,255,255,0.05);
				color: var(--muted);
				font-size: 0.85rem;
			}

			footer strong { color: var(--text); }

			@media (max-width: 640px) {
				.prizes { grid-template-columns: 1fr; }
				.step { flex-direction: column; gap: 0.5rem; }
				.section { padding: 3rem 1.25rem; }
				.tiktoks { grid-template-columns: 1fr; }
			}
		</style>
	</head>
	<body>

		<section class="hero">
			<div class="hero-bg"></div>
			<div class="hero-overlay"></div>
			<div class="hero-content">
				<h1>La Copa del Mundo 2026</h1>
				<p class="sub">En mot en, alla mot alla</p>
				<a href="#how" class="cta">Gå med</a>
				<a href="#leaderboard" class="cta" style="background: var(--celeste); margin-left: 12px;">Tabell</a>
			</div>
		</section>

		<section class="section" id="how">
			<h2>Så funkar det</h2>
			<p class="section-intro">Tre steg, sen är du med.</p>
			<div class="steps">
				<div class="step">
					<div class="step-num">1</div>
					<div>
						<h3>Skapa ditt lag</h3>
						<p>Gå till Aftonbladets <strong>VM-elvan</strong> och skapa ditt lag. Välj spelare, sätt din startelva, och tävla baserat på verklig matchstatistik.</p>
					</div>
				</div>
				<div class="step">
					<div class="step-num">2</div>
					<div>
						<h3>Swisha 300 kr</h3>
						<p>Skicka <strong>300 kr</strong> till Ruy via Swish: <strong>+46 70 306 42 11</strong>. Skriv ditt VM-elvan-lagnamn i meddelandet.</p>
					</div>
				</div>
				<div class="step">
					<div class="step-num">3</div>
					<div>
						<h3>Du är med!</h3>
						<p>När vi fått ditt lagnamn och betalning dyker du upp i deltagarlistan. Gå med i <a href="https://chat.whatsapp.com/LGL6yZKMdtl7GTJKZrEKeX" target="_blank" style="color: var(--celeste); text-decoration: underline;">WhatsApp-gruppen</a> för uppdateringar och snack. Avspark <strong>11 juni</strong>.</p>
					</div>
				</div>
			</div>
		</section>

		<div class="photo-break">
			<div class="photo-break-bg" style="background-image: url('/suarez.jpg');"></div>
			<div class="photo-break-overlay"></div>
		</div>

		<section class="section" id="swish">
			<h2>Betala</h2>
			<p class="section-intro">Swisha insatsen direkt.</p>
			<div class="swish-box">
				<h3>Insats</h3>
				<div class="amount">300 kr</div>

				<a class="swish-btn"
					href="swish://payment?data=%7B%22version%22%3A1%2C%22payee%22%3A%7B%22value%22%3A%22%2B46703064211%22%2C%22editable%22%3Afalse%7D%2C%22amount%22%3A%7B%22value%22%3A300%2C%22editable%22%3Afalse%7D%2C%22message%22%3A%7B%22value%22%3A%22La%20Copa%20del%20Mundo%202026%22%2C%22editable%22%3Atrue%7D%7D">
					Öppna Swish
				</a>

				<p class="swish-or">eller skanna QR-koden</p>

				<div class="swish-qr">
					<img src="/api/swish-qr" alt="Swish QR-kod — 300 kr till Ruy" />
				</div>
				<p class="swish-hint">Till: Ruy (+46 70 306 42 11) &bull; Meddelande fylls i automatiskt</p>
			</div>
		</section>

		<hr class="divider" />

		<section class="section">
			<h2>Potten</h2>
			<p class="section-intro">Vinnaren tar nästan allt.</p>
			<div class="prizes">
				<div class="prize">
					<div class="prize-place">1:a</div>
					<div class="prize-pct">85%</div>
					<div class="prize-label">av potten</div>
				</div>
				<div class="prize">
					<div class="prize-place">2:a</div>
					<div class="prize-pct">10%</div>
					<div class="prize-label">av potten</div>
				</div>
				<div class="prize">
					<div class="prize-place">3:a</div>
					<div class="prize-pct">5%</div>
					<div class="prize-label">av potten</div>
				</div>
			</div>
			<div class="prize-example">
				Med <strong>30 spelare</strong> = pott <strong>9 000 kr</strong>: 1:a &rarr; 7 650 kr &bull; 2:a &rarr; 900 kr &bull; 3:a &rarr; 450 kr
			</div>
		</section>

		<div class="photo-break">
			<div class="photo-break-bg" style="background-image: url('/hero.jpg');"></div>
			<div class="photo-break-overlay"></div>
		</div>

		<section class="section">
			<h2>Deltagare</h2>
			<p class="section-intro">Betalda och bekräftade.</p>
			<div class="participants-grid">
				<div class="participant"><span class="num">01</span> Ruy</div>
				<div class="participant empty"><span class="num">02</span> Din plats?</div>
				<div class="participant empty"><span class="num">03</span> Din plats?</div>
				<div class="participant empty"><span class="num">04</span> Din plats?</div>
				<div class="participant empty"><span class="num">05</span> Din plats?</div>
				<div class="participant empty"><span class="num">06</span> Din plats?</div>
			</div>
		</section>

		<div class="photo-break">
			<div class="photo-break-bg" style="background-image: url('/vmklar.jpg');"></div>
			<div class="photo-break-overlay"></div>
		</div>

		<section class="section section-wide" id="leaderboard">
			<!-- Main tabs -->
			<div class="main-tabs">
				<button class="main-tab active" onclick="switchMainTab('tabell')">Tabell</button>
				<button class="main-tab" onclick="switchMainTab('statistik')">Statistik</button>
				<button class="main-tab" onclick="switchMainTab('h2h')">Head to Head</button>
			</div>

			<div class="leaderboard-layout">
				<!-- Left column: main tab content -->
				<div>
					<div id="main-tab-tabell" class="main-tab-content active">
						<div id="leaderboard-container">
							<div class="leaderboard-loading">Laddar ställning...</div>
						</div>
					</div>

					<div id="main-tab-statistik" class="main-tab-content">
						<div id="stat-cards"></div>
					</div>

					<div id="main-tab-h2h" class="main-tab-content">
						<div id="h2h-container"></div>
					</div>
				</div>

				<!-- Right column: team panel -->
				<div class="team-panel" id="team-panel">
					<div class="team-panel-empty">
						<span class="arrow">&larr;</span>
						Klicka på ett lag i tabellen
					</div>
				</div>
			</div>
		</section>

		<script is:inline>
			// ---- TAB SWITCHING ----
			function switchMainTab(tab) {
				document.querySelectorAll('.main-tab').forEach(function(t) { t.classList.remove('active'); });
				document.querySelectorAll('.main-tab-content').forEach(function(c) { c.classList.remove('active'); });
				document.querySelector('.main-tab-content#main-tab-' + tab).classList.add('active');
				// Find the button by matching text
				document.querySelectorAll('.main-tab').forEach(function(t) {
					var map = { 'Tabell': 'tabell', 'Statistik': 'statistik', 'Head to Head': 'h2h' };
					if (map[t.textContent.trim()] === tab) t.classList.add('active');
				});
			}

			function switchTeamTab(tab) {
				document.querySelectorAll('.tp-tab').forEach(function(t) { t.classList.remove('active'); });
				document.querySelectorAll('.tp-tab-content').forEach(function(c) { c.classList.remove('active'); });
				var el = document.getElementById('tp-tab-' + tab);
				if (el) el.classList.add('active');
				document.querySelectorAll('.tp-tab').forEach(function(t) {
					if (t.getAttribute('data-tab') === tab) t.classList.add('active');
				});
			}

			var PAGE_SIZE = 10;
			var currentPage = 1;
			var leaderboardData = [];

			async function loadLeaderboard() {
				var container = document.getElementById('leaderboard-container');
				try {
					var res = await fetch('/api/leaderboard');
					if (!res.ok) throw new Error('API error');
					var data = await res.json();
					leaderboardData = data.leaderboard || [];

					if (leaderboardData.length === 0) {
						container.innerHTML = '<div class="leaderboard-loading">Inga lag registrerade ännu.</div>';
						return;
					}

					renderPage(1);
				} catch (e) {
					container.innerHTML = '<div class="leaderboard-loading">Kunde inte ladda ställningen.</div>';
				}
			}

			function renderPage(page) {
				currentPage = page;
				var container = document.getElementById('leaderboard-container');
				var totalPages = Math.ceil(leaderboardData.length / PAGE_SIZE);
				var start = (page - 1) * PAGE_SIZE;
				var pageData = leaderboardData.slice(start, start + PAGE_SIZE);

				var rows = pageData.map(function(entry) {
					var growthVal = entry.growth / 1000000;
					var scoreClass = growthVal > 0 ? 'positive' : 'zero';
					var scoreText = growthVal > 0 ? '+' + growthVal.toFixed(1) + 'M' : '0';
					var topClass = '';
					if (entry.position === 1) topClass = ' top1';
					else if (entry.position === 2) topClass = ' top2';
					else if (entry.position === 3) topClass = ' top3';
					var sel = entry.teamId === selectedTeamId ? ' selected' : '';
					return '<div class="lb-row' + topClass + sel + '" onclick="openTeam(' + entry.teamId + ')" data-id="' + entry.teamId + '">' +
						'<div class="lb-pos">' + entry.position + '</div>' +
						'<div class="lb-team"><div class="lb-team-name">' + escapeHtml(entry.teamName) + '</div>' +
						'<div class="lb-manager">' + escapeHtml(entry.manager) + '</div></div>' +
						'<div class="lb-score ' + scoreClass + '">' + scoreText + '</div>' +
						'</div>';
				}).join('');

				var pageButtons = '';
				for (var i = 1; i <= totalPages; i++) {
					pageButtons += '<button onclick="renderPage(' + i + ')" class="' + (i === page ? 'active' : '') + '">' + i + '</button>';
				}

				container.innerHTML =
					'<div class="lb-header"><span>#</span><span>Lag</span><span>Poäng</span></div>' +
					rows +
					(totalPages > 1 ? '<div class="leaderboard-pages">' + pageButtons + '</div>' : '') +
					'<p class="leaderboard-info">' + leaderboardData.length + ' lag &bull; Sida ' + page + ' av ' + totalPages + '</p>';
			}

			var selectedTeamId = null;

			async function openTeam(teamId) {
				selectedTeamId = teamId;
				var panel = document.getElementById('team-panel');
				panel.innerHTML = '<div class="tp-loading">Laddar lag...</div>';

				// Highlight selected row
				var rows = document.querySelectorAll('.lb-row');
				rows.forEach(function(r) { r.classList.remove('selected'); });
				var selected = document.querySelector('.lb-row[data-id="' + teamId + '"]');
				if (selected) selected.classList.add('selected');

				try {
					var res = await fetch('/api/team/' + teamId);
					if (!res.ok) throw new Error('Failed');
					var data = await res.json();

					var posNames = { 6: 'MV', 7: 'BACK', 8: 'MITT', 9: 'ANF' };
					var posCls = { 6: 'mv', 7: '', 8: '', 9: 'anf' };
					var playersHtml = '';
					if (data.players && data.players.length > 0) {
						playersHtml = '<div class="tp-section"><div class="tp-section-title">Uppställning</div>' +
							data.players.map(function(p) {
								var pos = posNames[p.position] || '';
								var cls = posCls[p.position] || '';
								var captain = p.isCaptain ? '<span class="captain">C</span>' : '';
								return '<div class="tp-player">' +
									'<span class="tp-pos-badge ' + cls + '">' + pos + '</span>' +
									'<span class="tp-player-name">' + escapeHtml(p.name) + captain + '</span>' +
									'<span class="tp-player-club">' + escapeHtml(p.clubAbbr || p.club) + '</span>' +
									'</div>';
							}).join('') + '</div>';
					} else {
						playersHtml = '<div class="tp-section"><p style="color:var(--muted);font-size:0.85rem;">Ingen uppställning ännu.</p></div>';
					}

					var roundsHtml = '';
					if (data.rounds && data.rounds.length > 0) {
						var maxGrowth = Math.max.apply(null, data.rounds.map(function(r) { return Math.abs(r.growth); }));
						roundsHtml = '<div class="tp-section"><div class="tp-section-title">Poäng per omgång</div>' +
							data.rounds.map(function(r) {
								var g = r.growth / 1000000;
								var cls = g > 0 ? 'pos' : g < 0 ? 'neg' : '';
								var text = g > 0 ? '+' + g.toFixed(2) + 'M' : g.toFixed(2) + 'M';
								var pct = maxGrowth > 0 ? Math.round(Math.abs(r.growth) / maxGrowth * 100) : 0;
								return '<div class="tp-round">' +
									'<span class="tp-round-num">' + r.round + '</span>' +
									'<div class="tp-round-bar"><div class="tp-round-bar-fill ' + cls + '" style="width:' + pct + '%"></div></div>' +
									'<span class="tp-round-val ' + cls + '">' + text + '</span>' +
									'</div>';
							}).join('') + '</div>';
					}

					var tradesHtml = '';
					if (data.rounds && data.rounds.length > 0) {
						// Group trades by round, include empty rounds
						var tradesByRound = {};
						// Initialize all rounds
						data.rounds.forEach(function(r) { tradesByRound[r.round] = []; });
						if (data.trades) {
							data.trades.forEach(function(t) {
								var r = t.round || 0;
								if (!tradesByRound[r]) tradesByRound[r] = [];
								tradesByRound[r].push(t);
							});
						}
						var roundKeys = Object.keys(tradesByRound).sort(function(a, b) { return b - a; });

						var totalBuys = (data.trades || []).filter(function(t) { return t.type === 'purchase'; }).length;
						var totalSells = (data.trades || []).filter(function(t) { return t.type === 'sale'; }).length;

						tradesHtml = '<div class="tp-section">' +
							'<div class="tp-trade-summary">' + totalBuys + ' köp, ' + totalSells + ' försäljningar totalt</div>' +
							roundKeys.map(function(rk, idx) {
								var trades = tradesByRound[rk];
								var buys = trades.filter(function(t) { return t.type === 'purchase'; });
								var sells = trades.filter(function(t) { return t.type === 'sale'; });
								var isEmpty = trades.length === 0;

								if (isEmpty) {
									return '<div class="tp-trade-group">' +
										'<div class="tp-trade-round-header tp-trade-empty-round">' +
										'<span>Omgång ' + rk + '</span>' +
										'<span class="tp-trade-count">inga byten</span>' +
										'</div></div>';
								}

								var isOpen = idx === 0 ? ' open' : '';
								var html = '<div class="tp-trade-group' + isOpen + '">' +
									'<div class="tp-trade-round-header" onclick="this.parentElement.classList.toggle(\'open\')">' +
									'<span><span class="chevron">&#9654;</span>Omgång ' + rk + '</span>' +
									'<span class="tp-trade-count">' + buys.length + ' in / ' + sells.length + ' ut</span>' +
									'</div>' +
									'<div class="tp-trade-list">';

								if (buys.length > 0) {
									html += buys.map(function(t) {
										return '<div class="tp-trade">' +
											'<span><span class="tp-trade-type buy">IN</span>' +
											escapeHtml(t.player) + '</span>' +
											'</div>';
									}).join('');
								}
								if (sells.length > 0) {
									html += sells.map(function(t) {
										return '<div class="tp-trade">' +
											'<span><span class="tp-trade-type sell">UT</span>' +
											escapeHtml(t.player) + '</span>' +
											'</div>';
									}).join('');
								}
								return html + '</div></div>';
							}).join('') + '</div>';
					}

					// Build cumulative growth chart
					var chartHtml = '';
					if (data.rounds && data.rounds.length > 1) {
						var cumulative = 0;
						var cumPoints = data.rounds.map(function(r) {
							cumulative += r.growth;
							return { x: r.round, y: cumulative };
						});
						chartHtml = '<div class="tp-section"><div class="tp-section-title">Utveckling</div>' +
							'<div class="line-chart-wrap">' +
							buildLineChart([{ label: data.name, color: '#fecc02', points: cumPoints }], { width: 400, height: 140 }) +
							'</div></div>';
					}

					panel.innerHTML =
						'<div class="tp-header"><h3>' + escapeHtml(data.name) + '</h3>' +
						'<div class="tp-manager">' + escapeHtml(data.manager) + '</div></div>' +
						'<div class="tp-tabs">' +
						'<button class="tp-tab active" data-tab="laget" onclick="switchTeamTab(\'laget\')">Laget</button>' +
						'<button class="tp-tab" data-tab="stats" onclick="switchTeamTab(\'stats\')">Stats</button>' +
						'<button class="tp-tab" data-tab="transfers" onclick="switchTeamTab(\'transfers\')">Transfers</button>' +
						'</div>' +
						'<div class="tp-tab-content active" id="tp-tab-laget">' + playersHtml + '</div>' +
						'<div class="tp-tab-content" id="tp-tab-stats">' + chartHtml + roundsHtml + '</div>' +
						'<div class="tp-tab-content" id="tp-tab-transfers">' + tradesHtml + '</div>';
				} catch (e) {
					panel.innerHTML = '<div class="tp-loading">Kunde inte ladda laget.</div>';
				}
			}

			function buildLineChart(series, opts) {
				// series: [{label, color, points: [{x, y}]}]
				// opts: {width, height, padX, padY}
				var W = opts.width || 400;
				var H = opts.height || 150;
				var pX = opts.padX || 36;
				var pY = opts.padY || 20;
				var chartW = W - pX * 2;
				var chartH = H - pY * 2;

				var allPoints = [];
				series.forEach(function(s) { allPoints = allPoints.concat(s.points); });
				if (allPoints.length === 0) return '';

				var minX = Math.min.apply(null, allPoints.map(function(p) { return p.x; }));
				var maxX = Math.max.apply(null, allPoints.map(function(p) { return p.x; }));
				var minY = Math.min.apply(null, allPoints.map(function(p) { return p.y; }));
				var maxY = Math.max.apply(null, allPoints.map(function(p) { return p.y; }));
				if (minY === maxY) { minY -= 1; maxY += 1; }
				var rangeX = maxX - minX || 1;
				var rangeY = maxY - minY;

				function sx(v) { return pX + ((v - minX) / rangeX) * chartW; }
				function sy(v) { return pY + chartH - ((v - minY) / rangeY) * chartH; }

				var svg = '<svg viewBox="0 0 ' + W + ' ' + H + '" xmlns="http://www.w3.org/2000/svg">';

				// Grid lines (horizontal)
				var gridSteps = 4;
				for (var g = 0; g <= gridSteps; g++) {
					var gy = pY + (g / gridSteps) * chartH;
					var gVal = maxY - (g / gridSteps) * rangeY;
					svg += '<line class="chart-grid" x1="' + pX + '" y1="' + gy + '" x2="' + (W - pX) + '" y2="' + gy + '"/>';
					svg += '<text class="chart-label" x="' + (pX - 4) + '" y="' + (gy + 3) + '" text-anchor="end">' + (gVal / 1000000).toFixed(1) + '</text>';
				}

				// X labels
				series[0].points.forEach(function(p) {
					svg += '<text class="chart-label" x="' + sx(p.x) + '" y="' + (H - 4) + '" text-anchor="middle">' + p.x + '</text>';
				});

				// Lines + areas + dots
				series.forEach(function(s) {
					if (s.points.length < 2) return;
					var sorted = s.points.slice().sort(function(a, b) { return a.x - b.x; });
					var pathD = sorted.map(function(p, i) { return (i === 0 ? 'M' : 'L') + sx(p.x).toFixed(1) + ',' + sy(p.y).toFixed(1); }).join(' ');

					// Area fill
					var areaD = pathD + ' L' + sx(sorted[sorted.length-1].x).toFixed(1) + ',' + sy(minY).toFixed(1) +
						' L' + sx(sorted[0].x).toFixed(1) + ',' + sy(minY).toFixed(1) + ' Z';
					svg += '<path class="chart-area" d="' + areaD + '" fill="' + s.color + '"/>';

					// Line
					svg += '<path class="chart-line" d="' + pathD + '" stroke="' + s.color + '"/>';

					// Dots
					sorted.forEach(function(p) {
						svg += '<circle class="chart-dot" cx="' + sx(p.x).toFixed(1) + '" cy="' + sy(p.y).toFixed(1) + '" r="3" fill="' + s.color + '" stroke="var(--bg)"/>';
					});
				});

				svg += '</svg>';
				return svg;
			}

			function escapeHtml(text) {
				var div = document.createElement('div');
				div.textContent = text;
				return div.innerHTML;
			}

			// ---- STATS & H2H ----
			var statsData = null;

			async function loadStats() {
				try {
					var res = await fetch('/api/stats');
					if (!res.ok) return;
					statsData = await res.json();
					renderStatCards(statsData.highlights);
					renderH2H(statsData.teams);
				} catch (e) {}
			}

			function renderStatCards(h) {
				var container = document.getElementById('stat-cards');
				var cards = [h.bestRound, h.worstRound, h.mostTrades, h.mostConsistent, h.longestStreak];
				container.innerHTML = '<div class="stat-cards">' + cards.map(function(c) {
					return '<div class="stat-card">' +
						'<div class="stat-card-label">' + escapeHtml(c.label) + '</div>' +
						'<div class="stat-card-team">' + escapeHtml(c.team) + '</div>' +
						'<div class="stat-card-detail">' + escapeHtml(c.detail) + '</div>' +
						'</div>';
				}).join('') + '</div>';
			}

			function renderH2H(teams) {
				var container = document.getElementById('h2h-container');
				var options = teams.map(function(t) {
					return '<option value="' + t.id + '">' + escapeHtml(t.name) + '</option>';
				}).join('');

				container.innerHTML =
					'<h3 style="font-family:Oswald;text-transform:uppercase;font-size:1.2rem;color:var(--yellow);margin-bottom:12px;">Head to Head</h3>' +
					'<div class="h2h-select">' +
					'<select id="h2h-a">' + options + '</select>' +
					'<span class="vs">VS</span>' +
					'<select id="h2h-b">' + options + '</select>' +
					'</div>' +
					'<div id="h2h-result"></div>';

				var selA = document.getElementById('h2h-a');
				var selB = document.getElementById('h2h-b');
				if (teams.length > 1) selB.selectedIndex = 1;
				selA.onchange = function() { updateH2H(teams); };
				selB.onchange = function() { updateH2H(teams); };
				updateH2H(teams);
			}

			function updateH2H(teams) {
				var idA = parseInt(document.getElementById('h2h-a').value);
				var idB = parseInt(document.getElementById('h2h-b').value);
				var teamA = teams.find(function(t) { return t.id === idA; });
				var teamB = teams.find(function(t) { return t.id === idB; });
				if (!teamA || !teamB) return;

				var result = document.getElementById('h2h-result');
				var maxRounds = Math.max(teamA.rounds.length, teamB.rounds.length);
				var winsA = 0, winsB = 0;

				var rows = '';
				for (var i = 0; i < maxRounds; i++) {
					var rA = teamA.rounds[i] || { round: i + 1, growth: 0 };
					var rB = teamB.rounds[i] || { round: i + 1, growth: 0 };
					var gA = rA.growth / 1000000;
					var gB = rB.growth / 1000000;
					var maxG = Math.max(Math.abs(rA.growth), Math.abs(rB.growth)) || 1;
					var pctA = Math.round(Math.abs(rA.growth) / maxG * 100);
					var pctB = Math.round(Math.abs(rB.growth) / maxG * 100);
					var clsA = rA.growth >= rB.growth ? 'win' : 'lose';
					var clsB = rB.growth >= rA.growth ? 'win' : 'lose';
					if (rA.growth > rB.growth) winsA++;
					else if (rB.growth > rA.growth) winsB++;

					rows += '<div class="h2h-round">' +
						'<span class="h2h-val left ' + clsA + '">' + (gA > 0 ? '+' : '') + gA.toFixed(2) + 'M</span>' +
						'<div class="h2h-bar-track"><div class="h2h-bar-fill left" style="width:' + pctA + '%"></div></div>' +
						'<span class="h2h-round-label">' + rA.round + '</span>' +
						'<div class="h2h-bar-track"><div class="h2h-bar-fill right" style="width:' + pctB + '%"></div></div>' +
						'<span class="h2h-val right ' + clsB + '">' + (gB > 0 ? '+' : '') + gB.toFixed(2) + 'M</span>' +
						'</div>';
				}

				var totalA = (teamA.totalGrowth / 1000000).toFixed(2);
				var totalB = (teamB.totalGrowth / 1000000).toFixed(2);

				// Build cumulative H2H chart
				var cumA = 0, cumB = 0;
				var ptsA = [], ptsB = [];
				for (var ci = 0; ci < maxRounds; ci++) {
					var crA = teamA.rounds[ci] || { round: ci + 1, growth: 0 };
					var crB = teamB.rounds[ci] || { round: ci + 1, growth: 0 };
					cumA += crA.growth; cumB += crB.growth;
					ptsA.push({ x: crA.round, y: cumA });
					ptsB.push({ x: crB.round, y: cumB });
				}

				var h2hChart = '<div class="line-chart-wrap">' +
					buildLineChart([
						{ label: teamA.name, color: '#fecc02', points: ptsA },
						{ label: teamB.name, color: '#75aadb', points: ptsB }
					], { width: 500, height: 180 }) +
					'<div class="chart-legend"><span class="leg-a">' + escapeHtml(teamA.name) + '</span><span class="leg-b">' + escapeHtml(teamB.name) + '</span></div>' +
					'</div>';

				result.innerHTML =
					h2hChart +
					'<div class="h2h-rounds">' + rows + '</div>' +
					'<div class="h2h-summary">' +
					'<div><div class="total">+' + totalA + 'M</div><div class="wins">' + winsA + ' vunna omgångar</div></div>' +
					'<div style="text-align:right"><div class="total">+' + totalB + 'M</div><div class="wins">' + winsB + ' vunna omgångar</div></div>' +
					'</div>';
			}

			loadLeaderboard();
			loadStats();
		</script>

