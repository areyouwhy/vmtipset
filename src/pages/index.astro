<html lang="sv">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>La Copa del Mundo 2026</title>
		<script>
			(function() {
				var t = localStorage.getItem('vmtipset-theme') || 'uru';
				document.documentElement.setAttribute('data-theme', t);
			})();
		</script>
		<style is:global>
			@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Inter:wght@400;500;600&display=swap');

			:root {
				--bg: #0a0e14;
				--card: #111825;
				--text: #f0f0f0;
				--muted: #8a9ab5;
				--yellow: #ffffff;
				--celeste: #75aadb;
			}

			/* Theme: Sweden */
			html[data-theme="swe"] {
				--yellow: #fecc02;
				--celeste: #005baa;
			}
			html[data-theme="swe"] .hero-bg { background-image: url('/swe-hero.webp'); }
			html[data-theme="swe"] [data-img="break-1"] { background-image: url('/swe-break-1.jpg'); }
			html[data-theme="swe"] [data-img="break-2"] { background-image: url('/swe-break-2.webp'); }
			html[data-theme="swe"] [data-img="break-3"] { background-image: url('/swe-break-3.jpg'); }

			/* Theme: Tunisia */
			html[data-theme="tun"] {
				--yellow: #e70013;
				--celeste: #ffffff;
			}
			html[data-theme="tun"] .hero-bg { background-image: url('/tun-hero.jpg'); }
			html[data-theme="tun"] [data-img="break-1"] { background-image: url('/tun-break-1.webp'); }
			html[data-theme="tun"] [data-img="break-2"] { background-image: url('/tun-break-2.jpeg'); }
			html[data-theme="tun"] [data-img="break-3"] { background-image: url('/tun-break-3.webp'); }

			/* Default images (URU) */
			.hero-bg { background-image: url('/uru-hero.jpg'); }
			[data-img="break-1"] { background-image: url('/uru-break-1.jpg'); }
			[data-img="break-2"] { background-image: url('/uru-break-2.jpg'); }
			[data-img="break-3"] { background-image: url('/uru-break-3.jpg'); }

			/* ---- THEME SWITCHER ---- */
			.theme-switcher {
				position: fixed;
				top: 1rem;
				right: 1rem;
				z-index: 1000;
				display: flex;
				gap: 0.35rem;
				background: rgba(10, 14, 20, 0.85);
				backdrop-filter: blur(8px);
				-webkit-backdrop-filter: blur(8px);
				padding: 0.3rem;
				border-radius: 999px;
				border: 1px solid rgba(255, 255, 255, 0.08);
				transition: opacity 0.3s;
			}

			.theme-switcher:not(:hover) { opacity: 0.6; }
			.theme-switcher:hover { opacity: 1; }

			.theme-btn {
				width: 34px;
				height: 34px;
				border-radius: 50%;
				border: 2px solid transparent;
				background: none;
				cursor: pointer;
				font-size: 1.1rem;
				display: flex;
				align-items: center;
				justify-content: center;
				transition: border-color 0.3s, transform 0.2s, opacity 0.3s;
				opacity: 0.45;
				padding: 0;
				line-height: 1;
			}

			.theme-btn:hover {
				opacity: 0.85;
				transform: scale(1.1);
			}

			.theme-btn.active {
				border-color: var(--yellow);
				opacity: 1;
			}

			.hero-bg,
			.photo-break-bg {
				transition: opacity 0.3s ease;
			}

			* { margin: 0; padding: 0; box-sizing: border-box; }
			html { scroll-behavior: smooth; }

			body {
				font-family: 'Inter', system-ui, sans-serif;
				background: var(--bg);
				color: var(--text);
				line-height: 1.6;
				padding-bottom: 0;
			}

			h1, h2, h3 {
				font-family: 'Oswald', sans-serif;
				text-transform: uppercase;
			}

			/* ---- HERO ---- */
			.hero {
				position: relative;
				height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				overflow: hidden;
			}

			.hero-bg {
				position: absolute;
				inset: 0;
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
				filter: brightness(0.3) saturate(1.2);
			}

			.hero-overlay {
				position: absolute;
				inset: 0;
				background: linear-gradient(
					to bottom,
					rgba(10, 14, 20, 0.2) 0%,
					rgba(10, 14, 20, 0.1) 50%,
					rgba(10, 14, 20, 0.9) 90%,
					rgba(10, 14, 20, 1) 100%
				);
			}

			.hero-content {
				position: relative;
				z-index: 1;
				padding: 2rem;
			}

			.hero h1 {
				font-size: clamp(2.5rem, 8vw, 5.5rem);
				font-weight: 700;
				line-height: 1;
				letter-spacing: 0.03em;
				margin-bottom: 1rem;
			}

			.hero .sub {
				font-family: 'Oswald', sans-serif;
				font-size: clamp(1rem, 2.5vw, 1.4rem);
				text-transform: uppercase;
				letter-spacing: 0.15em;
				color: var(--celeste);
				margin-bottom: 3rem;
				font-style: italic;
			}

			.hero-auth {
				margin-top: 2rem;
			}

			.hero-auth .auth-form {
				max-width: 280px;
				margin: 0 auto;
			}

			.hero-auth .auth-user-bar {
				justify-content: center;
			}

			.cta {
				display: inline-block;
				padding: 1rem 2.5rem;
				background: var(--yellow);
				color: var(--bg);
				font-family: 'Oswald', sans-serif;
				font-size: 1.15rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				text-decoration: none;
				transition: all 0.2s;
			}

			.cta:hover {
				background: #fff;
				transform: translateY(-2px);
				box-shadow: 0 8px 30px rgba(245, 197, 24, 0.2);
			}

			/* ---- SECTIONS ---- */
			.section {
				padding: 5rem 2rem;
				max-width: 800px;
				margin: 0 auto;
			}

			.section h2 {
				font-size: 2rem;
				margin-bottom: 0.5rem;
				color: var(--yellow);
			}

			.section-intro {
				color: var(--muted);
				margin-bottom: 2rem;
			}

			/* ---- STEPS ---- */
			.steps { display: grid; gap: 1.25rem; }

			.step {
				display: flex;
				gap: 1.5rem;
				align-items: flex-start;
				background: var(--card);
				padding: 1.75rem;
				border-left: 3px solid var(--celeste);
			}

			.step-num {
				font-family: 'Oswald', sans-serif;
				font-size: 2.2rem;
				font-weight: 700;
				color: var(--celeste);
				line-height: 1;
				flex-shrink: 0;
				width: 2rem;
				text-align: center;
			}

			.step h3 { font-size: 1.1rem; margin-bottom: 0.3rem; }
			.step p { color: var(--muted); }
			.step strong { color: var(--text); }

			/* ---- SWISH ---- */
			.swish-box {
				background: var(--card);
				padding: 2.5rem 2rem;
				text-align: center;
			}

			.swish-box h3 {
				font-size: 1.4rem;
				margin-bottom: 0.5rem;
			}

			.swish-box .amount {
				font-family: 'Oswald', sans-serif;
				font-size: 2.5rem;
				font-weight: 700;
				color: var(--yellow);
				margin-bottom: 1.5rem;
			}

			.swish-qr {
				background: #fff;
				display: inline-block;
				padding: 1rem;
				border-radius: 8px;
				margin-bottom: 1rem;
			}

			.swish-qr img {
				display: block;
				width: 200px;
				height: 200px;
			}

			.swish-btn {
				display: block;
				margin: 0 auto 1.5rem;
				padding: 1rem 2rem;
				background: #4DAB3D;
				color: #fff;
				font-family: 'Oswald', sans-serif;
				font-size: 1.15rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.03em;
				text-decoration: none;
				border-radius: 40px;
				transition: all 0.2s;
				width: fit-content;
			}

			.swish-btn:hover {
				background: #3d9a2e;
				transform: translateY(-2px);
				box-shadow: 0 6px 20px rgba(77, 171, 61, 0.3);
			}

			.swish-or {
				color: var(--muted);
				font-size: 0.85rem;
				margin-bottom: 1rem;
			}

			.swish-hint {
				color: var(--muted);
				font-size: 0.85rem;
				margin-top: 0.5rem;
			}

			/* ---- PRIZES ---- */
			.prizes {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.25rem;
				margin-bottom: 1.25rem;
			}

			.prize {
				background: var(--card);
				padding: 1.75rem 1.25rem;
				text-align: center;
			}

			.prize-place {
				font-family: 'Oswald', sans-serif;
				font-size: 1.3rem;
				font-weight: 700;
				margin-bottom: 0.2rem;
			}

			.prize:nth-child(1) .prize-place { color: var(--yellow); }
			.prize:nth-child(2) .prize-place { color: var(--celeste); }
			.prize:nth-child(3) .prize-place { color: #cd7f32; }

			.prize:nth-child(1) { border-top: 3px solid var(--yellow); }
			.prize:nth-child(2) { border-top: 3px solid var(--celeste); }
			.prize:nth-child(3) { border-top: 3px solid #cd7f32; }

			.prize-pct {
				font-family: 'Oswald', sans-serif;
				font-size: 2.8rem;
				font-weight: 700;
				line-height: 1;
			}

			.prize-label { color: var(--muted); font-size: 0.85rem; }

			.prize-example {
				background: var(--card);
				padding: 1.1rem;
				color: var(--muted);
				text-align: center;
				font-size: 0.9rem;
			}

			.prize-example strong { color: var(--text); }

			/* ---- HISTORY ---- */
			.history-card {
				background: var(--card);
				border-radius: 4px;
				padding: 24px;
				margin-bottom: 16px;
				border-left: 3px solid var(--yellow);
			}

			.history-card-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				margin-bottom: 16px;
			}

			.history-card-title {
				font-family: 'Oswald', sans-serif;
				font-size: 1.2rem;
				text-transform: uppercase;
			}

			.history-card-meta {
				font-size: 0.8rem;
				color: var(--muted);
				font-family: 'Oswald', sans-serif;
				letter-spacing: 0.04em;
			}

			.history-podium {
				display: grid;
				grid-template-columns: auto 1fr;
				gap: 4px 12px;
				align-items: center;
			}

			.history-pos {
				font-family: 'Oswald', sans-serif;
				font-size: 1.1rem;
				font-weight: 700;
				width: 28px;
				text-align: center;
			}

			.history-pos.gold { color: var(--yellow); }
			.history-pos.silver { color: var(--celeste); }
			.history-pos.bronze { color: #cd7f32; }

			.history-entry {
				padding: 6px 0;
				border-bottom: 1px solid rgba(255,255,255,0.04);
				display: flex;
				justify-content: space-between;
			}

			.history-entry:last-child { border-bottom: none; }

			.history-name { font-weight: 500; }
			.history-team { color: var(--muted); font-size: 0.85rem; }

			/* ---- PARTICIPANTS ---- */
			.participants-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
				gap: 0.6rem;
			}

			.participant {
				background: var(--card);
				padding: 0.8rem 1rem;
				display: flex;
				align-items: center;
				gap: 0.7rem;
				font-weight: 500;
			}

			.participant .num {
				font-family: 'Oswald', sans-serif;
				color: var(--celeste);
				font-weight: 600;
			}

			.participant.empty {
				opacity: 0.2;
				border: 1px dashed var(--muted);
				background: transparent;
			}

			/* ---- LEADERBOARD LOADING (reused) ---- */
			.leaderboard-loading {
				background: var(--card);
				border-radius: 4px;
				padding: 64px 24px;
				text-align: center;
				color: var(--muted);
				border: 1px solid rgba(255,255,255,0.04);
			}

			/* ---- PITCH VIEW ---- */
			.pitch {
				position: relative;
				width: 100%;
				aspect-ratio: 3/4;
				background: linear-gradient(175deg, #1a5c1a 0%, #2a7a2a 40%, #1a5c1a 100%);
				border-radius: 6px;
				overflow: hidden;
			}

			.pitch-lines {
				position: absolute;
				inset: 0;
				pointer-events: none;
			}

			.pitch-lines::before {
				content: '';
				position: absolute;
				top: 50%;
				left: 8%;
				right: 8%;
				height: 1px;
				background: rgba(255,255,255,0.18);
			}

			.pitch-lines::after {
				content: '';
				position: absolute;
				top: 50%;
				left: 50%;
				width: 60px;
				height: 60px;
				border: 1px solid rgba(255,255,255,0.18);
				border-radius: 50%;
				transform: translate(-50%, -50%);
			}

			.pitch-box-top, .pitch-box-bottom {
				position: absolute;
				left: 25%;
				right: 25%;
				height: 14%;
				border: 1px solid rgba(255,255,255,0.18);
			}
			.pitch-box-top { top: 0; border-top: none; }
			.pitch-box-bottom { bottom: 0; border-bottom: none; }

			.pitch-outline {
				position: absolute;
				top: 4%;
				bottom: 4%;
				left: 8%;
				right: 8%;
				border: 1px solid rgba(255,255,255,0.18);
				border-radius: 2px;
				pointer-events: none;
			}

			.pitch-player {
				position: absolute;
				transform: translate(-50%, -50%);
				text-align: center;
				cursor: pointer;
				z-index: 2;
				transition: transform 0.15s;
			}

			.pitch-player:hover {
				transform: translate(-50%, -50%) scale(1.12);
			}

			.pitch-dot {
				width: 34px;
				height: 34px;
				border-radius: 50%;
				margin: 0 auto;
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
				background: rgba(255,255,255,0.12);
				border: 2px solid rgba(255,255,255,0.25);
			}

			.pitch-dot.mv { border-color: rgba(117,170,219,0.6); }
			.pitch-dot.anf { border-color: rgba(254,204,2,0.5); }
			.pitch-dot.captain { box-shadow: 0 0 0 2px var(--yellow), 0 0 8px rgba(254,204,2,0.4); }

			.pitch-avatar {
				width: 100%;
				height: 100%;
				display: block;
			}

			.pitch-photo {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}

			.pitch-name {
				font-size: 0.6rem;
				font-family: 'Oswald', sans-serif;
				margin-top: 2px;
				white-space: nowrap;
				color: #fff;
				text-shadow: 0 1px 4px rgba(0,0,0,0.8), 0 0 2px rgba(0,0,0,0.5);
				letter-spacing: 0.02em;
				max-width: 72px;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			.pitch-fallback-list {
				padding: 12px 0;
			}

			/* ---- ADMIN ---- */
			.admin-section-title {
				font-family: 'Oswald', sans-serif;
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: var(--yellow);
				margin-bottom: 16px;
			}

			.admin-form {
				max-width: 400px;
			}

			.admin-label {
				display: block;
				font-size: 0.8rem;
				color: var(--muted);
				margin-bottom: 12px;
			}

			.admin-input {
				display: block;
				width: 100%;
				margin-top: 4px;
				padding: 8px 12px;
				background: rgba(255,255,255,0.06);
				border: 1px solid rgba(255,255,255,0.12);
				border-radius: 4px;
				color: var(--text);
				font-size: 0.9rem;
				outline: none;
				box-sizing: border-box;
			}

			.admin-input:focus { border-color: var(--celeste); }

			.admin-toggles {
				display: flex;
				flex-direction: column;
				gap: 8px;
				margin-bottom: 16px;
			}

			.admin-toggle {
				font-size: 0.85rem;
				color: var(--text);
				display: flex;
				align-items: center;
				gap: 8px;
				cursor: pointer;
			}

			.admin-toggle input { accent-color: var(--celeste); }

			.admin-teams-list {
				display: flex;
				flex-direction: column;
				gap: 8px;
			}

			.admin-team-row {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 10px 12px;
				background: rgba(255,255,255,0.03);
				border-radius: 4px;
				border: 1px solid rgba(255,255,255,0.06);
			}

			.admin-team-info {
				flex: 1;
			}

			.admin-team-name {
				font-family: 'Oswald', sans-serif;
				font-size: 0.9rem;
			}

			.admin-team-meta {
				font-size: 0.7rem;
				color: var(--muted);
			}

			.admin-team-actions {
				display: flex;
				gap: 6px;
			}

			.admin-action-btn {
				padding: 4px 12px;
				border: 1px solid rgba(255,255,255,0.12);
				border-radius: 3px;
				background: rgba(255,255,255,0.04);
				color: var(--text);
				font-size: 0.75rem;
				font-family: 'Oswald', sans-serif;
				cursor: pointer;
				text-transform: uppercase;
				letter-spacing: 0.04em;
			}

			.admin-action-btn:hover { background: rgba(255,255,255,0.08); }
			.admin-action-btn.approve { border-color: #22c55e; color: #22c55e; }
			.admin-action-btn.reject { border-color: #ef4444; color: #ef4444; }

			.admin-team-status {
				font-family: 'Oswald', sans-serif;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				padding: 4px 10px;
			}

			.admin-team-status.approved { color: #22c55e; }
			.admin-team-status.pending { color: #f59e0b; }
			.admin-team-status.rejected { color: #ef4444; }

			/* ---- BYGG LAG: AUTH ---- */
			.bygg-auth {
				text-align: center;
				padding: 32px 0;
			}

			.bygg-auth-title {
				font-family: 'Oswald', sans-serif;
				font-size: 1.6rem;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: var(--yellow);
				margin-bottom: 4px;
			}

			.bygg-auth-subtitle {
				color: var(--muted);
				font-size: 0.85rem;
				margin-bottom: 24px;
			}

			.bygg-auth-form {
				max-width: 280px;
				margin: 0 auto;
				display: flex;
				flex-direction: column;
				gap: 10px;
			}

			.bygg-auth-form input {
				padding: 10px 14px;
				background: rgba(255,255,255,0.06);
				border: 1px solid rgba(255,255,255,0.12);
				border-radius: 4px;
				color: var(--text);
				font-size: 0.9rem;
				outline: none;
				text-align: center;
			}

			.bygg-auth-form input:focus { border-color: var(--celeste); }

			.bygg-auth-buttons {
				display: flex;
				gap: 8px;
			}

			.bygg-auth-btn {
				flex: 1;
				padding: 10px;
				border: 1px solid rgba(255,255,255,0.15);
				border-radius: 4px;
				background: rgba(255,255,255,0.04);
				color: var(--text);
				font-family: 'Oswald', sans-serif;
				font-size: 0.9rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				cursor: pointer;
				transition: background 0.2s, border-color 0.2s;
			}

			.bygg-auth-btn:hover { background: rgba(255,255,255,0.08); }

			.bygg-auth-btn.primary {
				background: var(--celeste);
				color: #111;
				border-color: var(--celeste);
			}

			.bygg-auth-btn.primary:hover { opacity: 0.9; }

			.bygg-auth-error {
				color: #ef4444;
				font-size: 0.8rem;
				min-height: 1.2em;
			}

			/* User bar */
			.bygg-user-bar {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 8px 0;
				margin-bottom: 12px;
				border-bottom: 1px solid rgba(255,255,255,0.06);
			}

			.bygg-user-bar span {
				font-family: 'Oswald', sans-serif;
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
			}

			.bygg-logout-btn {
				background: none;
				border: none;
				color: var(--muted);
				font-size: 0.75rem;
				cursor: pointer;
				text-decoration: underline;
			}

			.bygg-logout-btn:hover { color: var(--text); }

			/* Captain hint */
			.bygg-captain-hint {
				font-size: 0.75rem;
				color: var(--muted);
				text-align: center;
				margin-bottom: 8px;
			}

			/* Captain star on pitch */
			.bygg-slot-captain {
				position: absolute;
				top: -6px;
				left: -6px;
				width: 16px;
				height: 16px;
				background: var(--yellow);
				border-radius: 50%;
				font-size: 0.55rem;
				line-height: 16px;
				text-align: center;
				color: #111;
				font-weight: bold;
				z-index: 3;
			}

			/* Save row */
			.bygg-save-row {
				margin-top: 16px;
				display: flex;
				align-items: center;
				gap: 12px;
			}

			.bygg-save-btn {
				padding: 12px 32px;
				background: var(--celeste);
				color: #111;
				border: none;
				border-radius: 4px;
				font-family: 'Oswald', sans-serif;
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				cursor: pointer;
				transition: opacity 0.2s;
			}

			.bygg-save-btn:hover { opacity: 0.9; }
			.bygg-save-btn:disabled { opacity: 0.4; cursor: not-allowed; }

			.bygg-save-status {
				font-size: 0.8rem;
				color: var(--muted);
			}

			.bygg-save-status.success { color: #22c55e; }
			.bygg-save-status.error { color: #ef4444; }

			/* ---- BYGG LAG ---- */
			.bygg-header {
				margin-bottom: 16px;
			}

			.bygg-budget-row {
				display: flex;
				align-items: center;
				gap: 12px;
				margin-bottom: 12px;
			}

			.bygg-budget-bar {
				flex: 1;
				height: 8px;
				background: rgba(255,255,255,0.08);
				border-radius: 4px;
				overflow: hidden;
			}

			.bygg-budget-fill {
				height: 100%;
				background: var(--celeste);
				border-radius: 4px;
				transition: width 0.3s, background 0.3s;
				width: 0%;
			}

			.bygg-budget-fill.warning { background: #f59e0b; }
			.bygg-budget-fill.over { background: #ef4444; }

			.bygg-budget-text {
				font-family: 'Oswald', sans-serif;
				font-size: 0.85rem;
				white-space: nowrap;
				min-width: 100px;
				text-align: right;
			}

			.bygg-controls {
				display: flex;
				gap: 8px;
				align-items: center;
			}

			.bygg-formation-select {
				flex: 1;
				padding: 8px 12px;
				background: rgba(255,255,255,0.06);
				border: 1px solid rgba(255,255,255,0.12);
				border-radius: 4px;
				color: var(--text);
				font-family: 'Oswald', sans-serif;
				font-size: 0.9rem;
			}

			.bygg-reset-btn {
				padding: 8px 16px;
				background: rgba(255,255,255,0.06);
				border: 1px solid rgba(255,255,255,0.12);
				border-radius: 4px;
				color: var(--muted);
				font-family: 'Oswald', sans-serif;
				font-size: 0.85rem;
				cursor: pointer;
				transition: color 0.2s, border-color 0.2s;
			}

			.bygg-reset-btn:hover { color: #ef4444; border-color: #ef4444; }

			.bygg-placeholder {
				text-align: center;
				padding: 48px 16px;
				color: var(--muted);
				font-size: 0.9rem;
			}

			/* Empty slot on pitch */
			.bygg-slot {
				position: absolute;
				transform: translate(-50%, -50%);
				text-align: center;
				cursor: pointer;
				z-index: 2;
				transition: transform 0.15s;
			}

			.bygg-slot:hover {
				transform: translate(-50%, -50%) scale(1.12);
			}

			.bygg-slot-dot {
				width: 34px;
				height: 34px;
				border-radius: 50%;
				margin: 0 auto;
				display: flex;
				align-items: center;
				justify-content: center;
				border: 2px dashed rgba(255,255,255,0.3);
				background: rgba(255,255,255,0.04);
				transition: border-color 0.2s, background 0.2s;
			}

			.bygg-slot:hover .bygg-slot-dot {
				border-color: var(--celeste);
				background: rgba(255,255,255,0.08);
			}

			.bygg-slot-dot.filled {
				border-style: solid;
				background: rgba(255,255,255,0.12);
				border-color: rgba(255,255,255,0.25);
			}

			.bygg-slot-dot.filled.mv { border-color: rgba(117,170,219,0.6); }
			.bygg-slot-dot.filled.anf { border-color: rgba(254,204,2,0.5); }

			.bygg-slot-plus {
				font-size: 1rem;
				color: rgba(255,255,255,0.3);
				line-height: 1;
			}

			.bygg-slot-name {
				font-size: 0.6rem;
				font-family: 'Oswald', sans-serif;
				margin-top: 2px;
				white-space: nowrap;
				color: #fff;
				text-shadow: 0 1px 4px rgba(0,0,0,0.8);
				letter-spacing: 0.02em;
				max-width: 72px;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			.bygg-slot-pos {
				font-size: 0.55rem;
				font-family: 'Oswald', sans-serif;
				color: rgba(255,255,255,0.5);
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}

			/* Remove badge on filled slot hover */
			.bygg-slot-remove {
				display: none;
				position: absolute;
				top: -4px;
				right: -4px;
				width: 16px;
				height: 16px;
				border-radius: 50%;
				background: #ef4444;
				color: #fff;
				font-size: 0.6rem;
				line-height: 16px;
				text-align: center;
				z-index: 3;
			}

			.bygg-slot:hover .bygg-slot-remove { display: block; }

			/* Squad summary */
			.bygg-squad-summary {
				margin-top: 16px;
				padding: 12px;
				background: rgba(255,255,255,0.03);
				border-radius: 6px;
				font-size: 0.8rem;
			}

			.bygg-summary-row {
				display: flex;
				justify-content: space-between;
				padding: 4px 0;
				border-bottom: 1px solid rgba(255,255,255,0.04);
			}

			.bygg-summary-row:last-child { border-bottom: none; }

			.bygg-summary-name { color: var(--text); }
			.bygg-summary-value { color: var(--muted); font-family: 'Oswald', sans-serif; }

			/* Player picker modal */
			.bygg-picker-overlay {
				display: none;
				position: fixed;
				inset: 0;
				background: rgba(0,0,0,0.7);
				z-index: 1000;
				align-items: center;
				justify-content: center;
				padding: 16px;
			}

			.bygg-picker-overlay.active { display: flex; }

			.bygg-picker-modal {
				background: var(--bg);
				border: 1px solid rgba(255,255,255,0.1);
				border-radius: 8px;
				width: 100%;
				max-width: 420px;
				max-height: 80vh;
				display: flex;
				flex-direction: column;
				overflow: hidden;
			}

			.bygg-picker-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 12px 16px;
				border-bottom: 1px solid rgba(255,255,255,0.06);
			}

			.bygg-picker-title {
				font-family: 'Oswald', sans-serif;
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
			}

			.bygg-picker-close {
				background: none;
				border: none;
				color: var(--muted);
				font-size: 1.4rem;
				cursor: pointer;
				padding: 0 4px;
				line-height: 1;
			}

			.bygg-picker-close:hover { color: var(--text); }

			.bygg-picker-search {
				padding: 8px 16px;
			}

			.bygg-picker-search input {
				width: 100%;
				padding: 8px 12px;
				background: rgba(255,255,255,0.06);
				border: 1px solid rgba(255,255,255,0.1);
				border-radius: 4px;
				color: var(--text);
				font-size: 0.85rem;
				outline: none;
				box-sizing: border-box;
			}

			.bygg-picker-search input:focus {
				border-color: var(--celeste);
			}

			.bygg-picker-sort-row {
				display: flex;
				gap: 0;
				padding: 0 16px 8px;
			}

			.bygg-picker-sort {
				flex: 1;
				padding: 6px;
				background: none;
				border: 1px solid rgba(255,255,255,0.06);
				color: var(--muted);
				font-family: 'Oswald', sans-serif;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				cursor: pointer;
			}

			.bygg-picker-sort:first-child { border-radius: 4px 0 0 4px; }
			.bygg-picker-sort:last-child { border-radius: 0 4px 4px 0; }
			.bygg-picker-sort.active { background: rgba(255,255,255,0.08); color: var(--text); }

			.bygg-picker-list {
				flex: 1;
				overflow-y: auto;
				padding: 0 16px 12px;
			}

			.bygg-picker-item {
				display: flex;
				align-items: center;
				gap: 10px;
				padding: 8px 4px;
				border-bottom: 1px solid rgba(255,255,255,0.04);
				cursor: pointer;
				transition: background 0.15s;
				border-radius: 4px;
			}

			.bygg-picker-item:hover { background: rgba(255,255,255,0.06); }

			.bygg-picker-item-avatar {
				width: 28px;
				height: 28px;
				border-radius: 50%;
				overflow: hidden;
				flex-shrink: 0;
				background: rgba(255,255,255,0.08);
			}

			.bygg-picker-item-avatar svg {
				width: 100%;
				height: 100%;
			}

			.bygg-picker-item-info {
				flex: 1;
				min-width: 0;
			}

			.bygg-picker-item-name {
				font-size: 0.85rem;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			.bygg-picker-item-club {
				font-size: 0.7rem;
				color: var(--muted);
			}

			.bygg-picker-item-value {
				font-family: 'Oswald', sans-serif;
				font-size: 0.85rem;
				text-align: right;
				white-space: nowrap;
			}

			.bygg-picker-item-growth {
				font-size: 0.7rem;
				color: var(--muted);
			}

			.bygg-picker-item-growth.positive { color: #22c55e; }

			/* ---- AUTH SECTION ---- */
			.auth-form {
				max-width: 320px;
				margin: 0 auto;
				display: flex;
				flex-direction: column;
				gap: 10px;
				text-align: center;
			}

			.auth-form input {
				padding: 12px 16px;
				background: rgba(255,255,255,0.06);
				border: 1px solid rgba(255,255,255,0.12);
				border-radius: 6px;
				color: var(--text);
				font-size: 1rem;
				outline: none;
				text-align: center;
			}

			.auth-form input:focus { border-color: var(--celeste); }

			.auth-buttons { display: flex; gap: 8px; }

			.auth-btn {
				flex: 1;
				padding: 12px;
				border: 1px solid rgba(255,255,255,0.15);
				border-radius: 6px;
				background: rgba(255,255,255,0.04);
				color: var(--text);
				font-family: 'Oswald', sans-serif;
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				cursor: pointer;
			}

			.auth-btn.primary {
				background: var(--celeste);
				color: #111;
				border-color: var(--celeste);
			}

			.auth-error { color: #ef4444; font-size: 0.8rem; min-height: 1.2em; }

			.auth-user-bar {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 16px;
				margin-bottom: 16px;
			}

			.auth-user-name {
				font-family: 'Oswald', sans-serif;
				font-size: 1.2rem;
				text-transform: uppercase;
			}

			.auth-logout-btn {
				background: none;
				border: none;
				color: var(--muted);
				font-size: 0.8rem;
				cursor: pointer;
				text-decoration: underline;
			}

			.auth-team-btn {
				display: block;
				margin: 0 auto;
				padding: 14px 32px;
				background: var(--celeste);
				color: #111;
				border: none;
				border-radius: 6px;
				font-family: 'Oswald', sans-serif;
				font-size: 1rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				cursor: pointer;
			}

			/* ---- LIGA STANDINGS ---- */
			.liga-team-row {
				display: flex;
				align-items: center;
				padding: 12px;
				border-bottom: 1px solid rgba(255,255,255,0.04);
				gap: 12px;
				cursor: pointer;
				transition: background 0.15s;
			}

			.liga-team-row:hover { background: rgba(255,255,255,0.03); }

			.liga-pos {
				font-family: 'Oswald', sans-serif;
				font-size: 1rem;
				width: 28px;
				text-align: center;
				color: var(--muted);
			}

			.liga-pos.top3 { color: var(--yellow); font-weight: 600; }

			.liga-team-info {
				flex: 1;
				min-width: 0;
			}

			.liga-team-name {
				font-family: 'Oswald', sans-serif;
				font-size: 0.9rem;
				display: block;
			}

			.liga-team-pts {
				font-family: 'Oswald', sans-serif;
				font-size: 0.9rem;
				color: var(--celeste);
			}

			.liga-team-players {
				font-size: 0.7rem;
				color: var(--muted);
				display: block;
			}

			.liga-team-last {
				font-size: 0.68rem;
				color: var(--muted);
				display: block;
			}

			.liga-team-last.pos { color: #22c55e; }
			.liga-team-last.neg { color: #ef4444; }

			.liga-team-detail {
				display: none;
				overflow: hidden;
			}

			.liga-team-detail.open {
				display: block;
				border-bottom: 1px solid rgba(255,255,255,0.06);
				background: rgba(255,255,255,0.02);
			}

			.detail-content {
				padding: 12px;
			}

			.detail-section {
				margin-bottom: 16px;
			}

			.detail-section-title {
				font-family: 'Oswald', sans-serif;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: var(--muted);
				margin-bottom: 8px;
			}

			.detail-round-row {
				display: flex;
				align-items: center;
				gap: 8px;
				padding: 3px 0;
			}

			.detail-round-num {
				font-family: 'Oswald', sans-serif;
				font-size: 0.72rem;
				color: var(--muted);
				width: 24px;
				flex-shrink: 0;
			}

			.detail-round-bar-wrap {
				flex: 1;
				height: 6px;
				background: rgba(255,255,255,0.04);
				border-radius: 3px;
				overflow: hidden;
			}

			.detail-round-bar {
				height: 100%;
				border-radius: 3px;
				transition: width 0.3s;
			}

			.detail-round-val {
				font-family: 'Oswald', sans-serif;
				font-size: 0.72rem;
				min-width: 55px;
				text-align: right;
				flex-shrink: 0;
			}

			.detail-round-val.pos { color: #22c55e; }
			.detail-round-val.neg { color: #ef4444; }

			/* ---- BOTTOM NAV ---- */
			.bottom-nav {
				position: fixed;
				bottom: 0;
				left: 0; right: 0;
				display: flex;
				justify-content: center;
				gap: 0;
				background: rgba(10, 14, 20, 0.95);
				backdrop-filter: blur(12px);
				border-top: 1px solid rgba(255,255,255,0.08);
				padding: 6px 0;
				padding-bottom: calc(6px + env(safe-area-inset-bottom, 0px));
				z-index: 100;
			}

			.bottom-nav-btn {
				flex: 1;
				max-width: 120px;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 2px;
				padding: 6px 12px;
				background: none;
				border: none;
				color: var(--muted);
				cursor: pointer;
				font-family: 'Oswald', sans-serif;
				transition: color 0.2s;
			}

			.bottom-nav-btn:hover, .bottom-nav-btn.active { color: var(--yellow); }
			.bottom-nav-icon { font-size: 1.2rem; }
			.bottom-nav-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.06em; }

			/* ---- FULLSCREEN VIEWS ---- */
			/* fullview styles removed — using appview instead */

			/* ---- RULES ---- */
			.rules-content p {
				font-size: 0.88rem;
				color: var(--muted);
				line-height: 1.6;
				margin-bottom: 12px;
			}

			.rules-heading {
				font-family: 'Oswald', sans-serif;
				font-size: 1.2rem;
				text-transform: uppercase;
				letter-spacing: 0.06em;
				color: var(--yellow);
				margin-bottom: 8px;
			}

			.rules-section {
				margin-bottom: 20px;
			}

			.rules-subheading {
				font-family: 'Oswald', sans-serif;
				font-size: 0.9rem;
				text-transform: uppercase;
				letter-spacing: 0.04em;
				color: var(--text);
				margin-bottom: 8px;
				padding-bottom: 4px;
				border-bottom: 1px solid rgba(255,255,255,0.06);
			}

			.rules-list {
				list-style: none;
				padding: 0;
			}

			.rules-list li {
				font-size: 0.85rem;
				padding: 6px 0;
				padding-left: 16px;
				position: relative;
				color: var(--text);
			}

			.rules-list li::before {
				content: '—';
				position: absolute;
				left: 0;
				color: var(--muted);
			}

			.rules-table {
				display: flex;
				flex-direction: column;
			}

			.rules-row {
				display: flex;
				justify-content: space-between;
				padding: 5px 0;
				font-size: 0.85rem;
				border-bottom: 1px solid rgba(255,255,255,0.03);
			}

			.rules-pts {
				font-family: 'Oswald', sans-serif;
				font-weight: 600;
				min-width: 50px;
				text-align: right;
			}

			.rules-pts.pos { color: #22c55e; }
			.rules-pts.neg { color: #ef4444; }

			.rules-prizes {
				display: flex;
				gap: 12px;
				margin-bottom: 8px;
			}

			.rules-prize {
				flex: 1;
				text-align: center;
				padding: 10px 8px;
				background: rgba(255,255,255,0.03);
				border-radius: 4px;
				font-size: 0.8rem;
			}

			.rules-prize-pos {
				display: block;
				font-family: 'Oswald', sans-serif;
				font-size: 1.1rem;
				color: var(--yellow);
				margin-bottom: 2px;
			}

			.rules-note {
				font-size: 0.78rem;
				color: var(--muted);
				font-style: italic;
			}

			/* ---- APP VIEWS ---- */
			.appview {
				display: none;
				min-height: 100vh;
				padding-bottom: 60px;
			}

			.appview.active { display: block; }

			.appview-header {
				padding: 16px;
				border-bottom: 1px solid rgba(255,255,255,0.06);
				position: sticky;
				top: 0;
				background: var(--bg);
				z-index: 10;
			}

			.appview-title {
				font-family: 'Oswald', sans-serif;
				font-size: 1.2rem;
				text-transform: uppercase;
				letter-spacing: 0.06em;
			}

			.appview-body {
				padding: 16px;
			}

			/* ---- PHOTO BREAK ---- */
			.photo-break {
				position: relative;
				height: 60vh;
				min-height: 350px;
				overflow: hidden;
			}

			.photo-break-bg {
				position: absolute;
				inset: 0;
				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
				background-attachment: fixed;
				filter: brightness(0.4) saturate(1.2);
			}

			.photo-break-overlay {
				position: absolute;
				inset: 0;
				background: linear-gradient(
					to bottom,
					rgba(10, 14, 20, 1) 0%,
					rgba(10, 14, 20, 0) 15%,
					rgba(10, 14, 20, 0) 85%,
					rgba(10, 14, 20, 1) 100%
				);
			}

			@media (max-width: 768px) {
				.photo-break-bg {
					background-attachment: scroll;
				}
				.photo-break { height: 40vh; min-height: 250px; }
			}

			/* ---- DIVIDER ---- */
			.divider {
				max-width: 800px;
				margin: 0 auto;
