		<script is:inline>
			// ---- THEME SWITCHER ----
			(function() {
				var THEMES = ['uru', 'swe', 'tun'];
				var stored = localStorage.getItem('vmtipset-theme');
				var current = THEMES.indexOf(stored) >= 0 ? stored : 'uru';

				document.documentElement.setAttribute('data-theme', current);

				// Set subtitle for persisted theme
				var SUBS_INIT = { uru: 'Uruguay nomaaa', swe: 'Kanna pa kanna pa!', tun: 'Ri ri Riahi!' };
				var subEl = document.getElementById('hero-sub');
				if (subEl) subEl.textContent = SUBS_INIT[current] || SUBS_INIT.uru;

				document.querySelectorAll('.theme-btn').forEach(function(btn) {
					if (btn.getAttribute('data-theme') === current) {
						btn.classList.add('active');
					} else {
						btn.classList.remove('active');
					}

					var SUBS = { uru: 'Uruguay nomaaa', swe: 'Kanna pa kanna pa!', tun: 'Ri ri Riahi!' };

					btn.addEventListener('click', function() {
						var theme = this.getAttribute('data-theme');

						// Crossfade images
						var imgs = document.querySelectorAll('.hero-bg, .photo-break-bg');
						imgs.forEach(function(el) { el.style.opacity = '0'; });

						setTimeout(function() {
							document.documentElement.setAttribute('data-theme', theme);
							localStorage.setItem('vmtipset-theme', theme);
							imgs.forEach(function(el) { el.style.opacity = '1'; });
						}, 300);

						// Update subtitle
						var sub = document.getElementById('hero-sub');
						if (sub) sub.textContent = SUBS[theme] || SUBS.uru;

						document.querySelectorAll('.theme-btn').forEach(function(b) {
							b.classList.remove('active');
						});
						this.classList.add('active');
					});
				});
			})();

			// ---- UTILITIES ----
			function escapeHtml(text) {
				var div = document.createElement('div');
				div.textContent = text;
				return div.innerHTML;
			}

			function buildPlayerAvatar(skin, hair) {
				var s = skin || '#C68642';
				var h = hair || '#1a1a1a';
				return '<svg class="pitch-avatar" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">' +
					'<circle cx="18" cy="20" r="14" fill="' + s + '"/>' +
					'<ellipse cx="18" cy="10" rx="13" ry="9" fill="' + h + '"/>' +
					'<circle cx="12" cy="20" r="1.5" fill="#111"/>' +
					'<circle cx="24" cy="20" r="1.5" fill="#111"/>' +
					'</svg>';
			}

			var cachedRuleset = null;

			async function getRuleset() {
				if (cachedRuleset) return cachedRuleset;
				try {
					var res = await fetch('/api/ruleset');
					if (!res.ok) return null;
					cachedRuleset = await res.json();
					return cachedRuleset;
				} catch { return null; }
			}

			// ---- PLAYER DATA ----
			var allPlayers = [];
			var playersLoaded = false;

			async function loadPlayers() {
				if (playersLoaded) return;
				try {
					var res = await fetch('/api/players');
					if (!res.ok) throw new Error('Failed');
					allPlayers = await res.json();
					playersLoaded = true;
				} catch (e) {
					console.error('Could not load players', e);
				}
			}

			// ---- AUTH ----
			var currentUser = null;

			async function checkSession() {
				try {
					var res = await fetch('/api/fantasy/me', { credentials: 'same-origin' });
					if (!res.ok) return null;
					var data = await res.json();
					return data.authenticated ? data : null;
				} catch { return null; }
			}

			async function doRegister() {
				var name = document.getElementById('auth-name').value.trim();
				var pin = document.getElementById('auth-pin').value.trim();
				var errEl = document.getElementById('auth-error');
				errEl.textContent = '';
				if (!name || name.length < 2) { errEl.textContent = 'Lagnamnet maste vara minst 2 tecken'; return; }
				if (!/^\d{4}$/.test(pin)) { errEl.textContent = 'PIN maste vara exakt 4 siffror'; return; }
				try {
					var res = await fetch('/api/fantasy/register', {
						method: 'POST', headers: { 'Content-Type': 'application/json' },
						credentials: 'same-origin', body: JSON.stringify({ teamName: name, pin: pin }),
					});
					var data = await res.json();
					if (!res.ok) { errEl.textContent = data.error || 'Nagot gick fel'; return; }
					var me = await checkSession();
					if (me) {
						onLoginSuccess(me);
					}
				} catch (e) { errEl.textContent = 'Natverksfel'; }
			}

			async function doLogin() {
				var name = document.getElementById('auth-name').value.trim();
				var pin = document.getElementById('auth-pin').value.trim();
				var errEl = document.getElementById('auth-error');
				errEl.textContent = '';
				if (!name) { errEl.textContent = 'Ange ditt lagnamn'; return; }
				if (!pin) { errEl.textContent = 'Ange din PIN'; return; }
				try {
					var res = await fetch('/api/fantasy/login', {
						method: 'POST', headers: { 'Content-Type': 'application/json' },
						credentials: 'same-origin', body: JSON.stringify({ teamName: name, pin: pin }),
					});
					var data = await res.json();
					if (!res.ok) { errEl.textContent = data.error || 'Nagot gick fel'; return; }
					var me = await checkSession();
					if (me) {
						onLoginSuccess(me);
					}
				} catch (e) { errEl.textContent = 'Natverksfel'; }
			}

			async function doLogout() {
				await fetch('/api/fantasy/logout', { method: 'POST', credentials: 'same-origin' });
				currentUser = null;
				document.getElementById('auth-guest').style.display = '';
				document.getElementById('auth-user').style.display = 'none';
				switchView('home');
			}

			function onLoginSuccess(session) {
				currentUser = session;
				document.getElementById('auth-guest').style.display = 'none';
				document.getElementById('auth-user').style.display = '';
				document.getElementById('auth-user-name').textContent = session.teamName;
				showMittlagNav();
				switchView('mittlag');
				if (window.initCopaBuilder) window.initCopaBuilder(session);
			}

			// Wire auth buttons
			document.getElementById('auth-register-btn').addEventListener('click', doRegister);
			document.getElementById('auth-login-btn').addEventListener('click', doLogin);
			document.getElementById('auth-logout-btn').addEventListener('click', doLogout);
			document.getElementById('auth-pin').addEventListener('keydown', function(e) { if (e.key === 'Enter') doRegister(); });
			document.getElementById('auth-open-team').addEventListener('click', function() {
				switchView('mittlag');
			});

			// ---- BOTTOM NAV ----
			function showMittlagNav() {
				document.getElementById('nav-mittlag').style.display = '';
			}

			function switchView(view) {
				// If not logged in and trying to access Mitt lag, redirect to Home with error
				if (view === 'mittlag' && !currentUser) {
					view = 'home';
					var errEl = document.getElementById('auth-error');
					if (errEl) {
						errEl.textContent = 'Du måste logga in för att se ditt lag';
						errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
					}
				}

				document.querySelectorAll('.appview').forEach(function(v) { v.classList.remove('active'); });

				document.querySelectorAll('.bottom-nav-btn').forEach(function(btn) {
					btn.classList.toggle('active', btn.getAttribute('data-view') === view);
				});

				var target = document.getElementById('view-' + view);
				if (target) {
					target.classList.add('active');
					window.scrollTo(0, 0);
				}

				if (view === 'tabell') loadStandings();
				if (view === 'admin' && window.initAdmin) window.initAdmin();
			}

			// Nav button clicks
			document.querySelectorAll('.bottom-nav-btn').forEach(function(btn) {
				btn.addEventListener('click', function() {
					switchView(btn.getAttribute('data-view'));
				});
			});

			// Back buttons
			document.getElementById('mittlag-back').addEventListener('click', function() {
				switchView('home');
			});
			document.getElementById('admin-back').addEventListener('click', function() {
				switchView('home');
			});
			document.getElementById('regler-back').addEventListener('click', function() {
				switchView('home');
			});

			// Admin trigger (hidden gear in footer)
			document.getElementById('admin-trigger').addEventListener('click', function() {
				switchView('admin');
			});

			// ---- TEAM BUILDER (Copa Liga) ----
			(function() {
				var BUDGET = 50000000; // default 50M, updated from league config
				var copaFormations = [];
				var copaSelectedFormation = null;
				var copaSlots = [];
				var copaLoaded = false;
				var copaPickerSlotIndex = -1;
				var copaPickerSort = { key: 'value', dir: -1 };
				var copaUser = null;
				var copaInited = false;

				function $(id) { return document.getElementById(id); }

				// ---- Pre-populate from saved team ----
				async function populateFromSaved(savedData) {
					if (!savedData || !savedData.players || savedData.players.length === 0) return;
					await ensureCopaData();
					if (savedData.formationId) {
						$('copa-formation-select').value = savedData.formationId;
						copaSelectedFormation = copaFormations.find(function(f) { return f.id === savedData.formationId; }) || null;
						if (copaSelectedFormation) {
							copaSlots = copaSelectedFormation.slots.map(function(s) {
								return { positionId: s.positionId, x: s.x, y: s.y, player: null, isCaptain: false };
							});
						}
					}
					if (copaSlots.length > 0 && allPlayers.length > 0) {
						var slotsByPos = {};
						copaSlots.forEach(function(s, idx) {
							if (!slotsByPos[s.positionId]) slotsByPos[s.positionId] = [];
							slotsByPos[s.positionId].push(idx);
						});
						savedData.players.forEach(function(sp) {
							var pd = allPlayers.find(function(p) { return p.playerId === sp.playerId; });
							if (!pd) return;
							var slots = slotsByPos[pd.position];
							if (!slots) return;
							for (var i = 0; i < slots.length; i++) {
								if (!copaSlots[slots[i]].player) {
									copaSlots[slots[i]].player = pd;
									copaSlots[slots[i]].isCaptain = sp.isCaptain;
									break;
								}
							}
						});
					}
					renderPitch();
					updateBudget();
					updateSaveRow();
				}

				// ---- Data loading ----
				async function ensureCopaData() {
					if (!playersLoaded) await loadPlayers();
					if (!copaLoaded) {
						var ruleset = await getRuleset();
						if (ruleset && ruleset.formations) {
							copaFormations = ruleset.formations;
							var sel = $('copa-formation-select');
							copaFormations.forEach(function(f) {
								var opt = document.createElement('option');
								opt.value = f.id;
								opt.textContent = f.name.trim();
								sel.appendChild(opt);
							});
						}
						// Load league config for budget
						try {
							var cfgRes = await fetch('/api/fantasy/admin/config');
							if (cfgRes.ok) {
								var cfg = await cfgRes.json();
								if (cfg.startingBudget) BUDGET = cfg.startingBudget;
							}
						} catch {}
						copaLoaded = true;
					}
				}

				async function initBuilder(session) {
					copaUser = { teamId: session.teamId, teamName: session.teamName };
					await ensureCopaData();
					await populateFromSaved(session);
				}

				// ---- Budget ----
				function copaSpent() {
					var t = 0; copaSlots.forEach(function(s) { if (s.player) t += s.player.value; }); return t;
				}

				function updateBudget() {
					var spent = copaSpent();
					var remaining = BUDGET - spent;
					var pct = Math.min(100, (spent / BUDGET) * 100);
					var fill = $('copa-budget-fill');
					var text = $('copa-budget-text');
					fill.style.width = pct + '%';
					fill.classList.remove('warning', 'over');
					if (remaining < 0) fill.classList.add('over');
					else if (pct > 80) fill.classList.add('warning');
					text.textContent = (remaining / 1000000).toFixed(2) + 'M kvar';
					text.style.color = remaining < 0 ? '#ef4444' : '';
				}

				// ---- Pitch rendering ----
				function renderPitch() {
					var container = $('copa-pitch-container');
					if (!copaSelectedFormation) {
						container.innerHTML = '<div class="bygg-placeholder">Valj en formation for att borja bygga ditt lag.</div>';
						$('copa-squad-summary').innerHTML = '';
						updateSaveRow();
						return;
					}
					var posNames = { 6: 'MV', 7: 'Back', 8: 'Mitt', 9: 'Anf' };
					var posCls = { 6: 'mv', 7: '', 8: '', 9: 'anf' };
					var html = copaSlots.map(function(slot, idx) {
						var left = slot.x, top = 100 - slot.y;
						var pLeft = 10 + (left / 100) * 80, pTop = 6 + (top / 100) * 88;
						if (slot.player) {
							var p = slot.player, cls = posCls[slot.positionId] || '';
							var lastName = p.name.split(' ').slice(-1)[0];
							var cap = slot.isCaptain ? '<div class="bygg-slot-captain">C</div>' : '';
							return '<div class="bygg-slot" style="left:' + pLeft + '%;top:' + pTop + '%" data-slot="' + idx + '">' +
								cap + '<div class="bygg-slot-remove">&times;</div>' +
								'<div class="bygg-slot-dot filled ' + cls + (slot.isCaptain ? ' captain' : '') + '">' + buildPlayerAvatar(p.skinColor, p.hairColor) + '</div>' +
								'<div class="bygg-slot-name">' + escapeHtml(lastName) + '</div></div>';
						}
						return '<div class="bygg-slot" style="left:' + pLeft + '%;top:' + pTop + '%" data-slot="' + idx + '">' +
							'<div class="bygg-slot-dot"><span class="bygg-slot-plus">+</span></div>' +
							'<div class="bygg-slot-pos">' + (posNames[slot.positionId] || '') + '</div></div>';
					}).join('');

					container.innerHTML = '<div class="pitch"><div class="pitch-outline"></div><div class="pitch-lines"></div><div class="pitch-box-top"></div><div class="pitch-box-bottom"></div>' + html + '</div>';

					container.querySelectorAll('.bygg-slot').forEach(function(el) {
						el.addEventListener('click', function(e) {
							var idx = parseInt(el.getAttribute('data-slot'));
							var slot = copaSlots[idx];
							if (slot.player && e.target.closest('.bygg-slot-remove')) {
								// X button — remove player
								slot.player = null; slot.isCaptain = false; renderPitch(); updateBudget();
							} else if (slot.player) {
								// Tap player — toggle captain
								toggleCaptain(idx);
							} else {
								// Empty slot — open picker
								openPicker(idx);
							}
						});
					});

					var filled = copaSlots.filter(function(s) { return s.player; }).length;
					var hasCap = copaSlots.some(function(s) { return s.isCaptain; });
					$('copa-captain-hint').style.display = (filled > 0 && !hasCap) ? '' : 'none';
					renderSummary();
					updateSaveRow();
				}

				function toggleCaptain(idx) {
					copaSlots.forEach(function(s) { s.isCaptain = false; });
					copaSlots[idx].isCaptain = true;
					renderPitch();
				}

				function updateSaveRow() {
					var row = $('copa-save-row');
					var btn = $('copa-save-btn');
					var status = $('copa-save-status');
					if (!copaUser || !copaSelectedFormation) { row.style.display = 'none'; return; }
					var filled = copaSlots.filter(function(s) { return s.player; }).length;
					var hasCap = copaSlots.some(function(s) { return s.isCaptain; });
					var withinBudget = copaSpent() <= BUDGET;

					if (filled === 0) { row.style.display = 'none'; return; }
					row.style.display = 'flex';

					if (filled < 11) {
						btn.disabled = true;
						status.textContent = filled + '/11 spelare valda';
						status.className = 'bygg-save-status';
					} else if (!hasCap) {
						btn.disabled = true;
						status.textContent = 'Tryck på en spelare för att välja kapten';
						status.className = 'bygg-save-status';
					} else if (!withinBudget) {
						btn.disabled = true;
						status.textContent = 'Över budget';
						status.className = 'bygg-save-status error';
					} else {
						btn.disabled = false;
						status.textContent = '';
					}
				}

				function renderSummary() {
					var el = $('copa-squad-summary');
					var picked = copaSlots.filter(function(s) { return s.player; });
					if (picked.length === 0) { el.innerHTML = ''; return; }
					var posNames = { 6: 'MV', 7: 'Back', 8: 'Mitt', 9: 'Anf' };
					var rows = picked.map(function(s) {
						var p = s.player, cap = s.isCaptain ? ' <span style="color:var(--yellow)">C</span>' : '';
						return '<div class="bygg-summary-row"><span class="bygg-summary-name">' + escapeHtml(p.name) + cap +
							' <span style="color:var(--muted);font-size:0.7rem">' + (posNames[s.positionId] || '') + ' \u00b7 ' + escapeHtml(p.clubAbbr || p.club) +
							'</span></span><span class="bygg-summary-value">' + (p.value / 1000000).toFixed(2) + 'M</span></div>';
					});
					var spent = copaSpent();
					rows.push('<div class="bygg-summary-row" style="margin-top:4px;padding-top:8px;border-top:1px solid rgba(255,255,255,0.08)">' +
						'<span class="bygg-summary-name" style="font-family:Oswald,sans-serif;text-transform:uppercase;letter-spacing:0.04em">Totalt</span>' +
						'<span class="bygg-summary-value">' + (spent / 1000000).toFixed(2) + 'M / ' + (BUDGET / 1000000).toFixed(0) + 'M</span></div>');
					el.innerHTML = rows.join('');
				}

				// ---- Player picker ----
				function openPicker(slotIdx) {
					copaPickerSlotIndex = slotIdx;
					var posNames = { 6: 'Malvakt', 7: 'Back', 8: 'Mittfaltare', 9: 'Anfallare' };
					$('bygg-picker-title').textContent = 'Valj ' + (posNames[copaSlots[slotIdx].positionId] || 'spelare');
					$('bygg-picker-search-input').value = '';
					$('bygg-picker-overlay').classList.add('active');
					renderPickerList();
					$('bygg-picker-search-input').focus();
				}

				function closePicker() {
					$('bygg-picker-overlay').classList.remove('active');
					copaPickerSlotIndex = -1;
				}

				function renderPickerList() {
					var list = $('bygg-picker-list');
					if (copaPickerSlotIndex < 0) return;
					var slot = copaSlots[copaPickerSlotIndex];
					var query = $('bygg-picker-search-input').value.toLowerCase().trim();
					var pickedIds = {};
					copaSlots.forEach(function(s) { if (s.player) pickedIds[s.player.playerId] = true; });
					var filtered = allPlayers.filter(function(p) {
						if (p.position !== slot.positionId) return false;
						if (pickedIds[p.playerId]) return false;
						if (query && p.name.toLowerCase().indexOf(query) < 0 && p.club.toLowerCase().indexOf(query) < 0 && (p.clubAbbr || '').toLowerCase().indexOf(query) < 0) return false;
						return true;
					});
					filtered.sort(function(a, b) { return ((a[copaPickerSort.key] || 0) - (b[copaPickerSort.key] || 0)) * copaPickerSort.dir; });
					if (!filtered.length) { list.innerHTML = '<div style="padding:16px;text-align:center;color:var(--muted)">Inga spelare hittades</div>'; return; }
					list.innerHTML = filtered.slice(0, 100).map(function(p) {
						var gc = p.totalGrowth > 0 ? ' positive' : '';
						var gs = (p.totalGrowth >= 0 ? '+' : '') + (p.totalGrowth / 1000000).toFixed(2) + 'M';
						return '<div class="bygg-picker-item" data-pid="' + p.playerId + '"><div class="bygg-picker-item-avatar">' +
							buildPlayerAvatar(p.skinColor, p.hairColor) + '</div><div class="bygg-picker-item-info"><div class="bygg-picker-item-name">' +
							escapeHtml(p.name) + '</div><div class="bygg-picker-item-club">' + escapeHtml(p.clubAbbr || p.club) +
							'</div></div><div style="text-align:right"><div class="bygg-picker-item-value">' + (p.value / 1000000).toFixed(2) +
							'M</div><div class="bygg-picker-item-growth' + gc + '">' + gs + '</div></div></div>';
					}).join('');
					list.querySelectorAll('.bygg-picker-item').forEach(function(el) {
						el.addEventListener('click', function() {
							var pid = parseInt(el.getAttribute('data-pid'));
							var player = allPlayers.find(function(p) { return p.playerId === pid; });
							if (player && copaPickerSlotIndex >= 0) {
								copaSlots[copaPickerSlotIndex].player = player;
								closePicker();
								renderPitch();
								updateBudget();
							}
						});
					});
				}

				// ---- Save team ----
				async function saveTeam() {
					if (!copaUser || !copaSelectedFormation) return;
					var btn = $('copa-save-btn'), status = $('copa-save-status');
					btn.disabled = true; status.textContent = 'Sparar...'; status.className = 'bygg-save-status';
					var players = [];
					copaSlots.forEach(function(s, idx) {
						if (s.player) players.push({ playerId: s.player.playerId, slotIndex: idx, isCaptain: s.isCaptain });
					});
					try {
						var res = await fetch('/api/fantasy/team/save', {
							method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
							body: JSON.stringify({ formationId: copaSelectedFormation.id, players: players }),
						});
						var data = await res.json();
						if (!res.ok) { status.textContent = data.error || 'Kunde inte spara'; status.className = 'bygg-save-status error'; }
						else { status.textContent = 'Sparat!'; status.className = 'bygg-save-status success'; }
					} catch (e) { status.textContent = 'Natverksfel'; status.className = 'bygg-save-status error'; }
					btn.disabled = false;
				}

				// ---- Event bindings ----
				$('copa-save-btn').addEventListener('click', saveTeam);

				$('copa-formation-select').addEventListener('change', function() {
					var id = parseInt(this.value);
					copaSelectedFormation = copaFormations.find(function(f) { return f.id === id; }) || null;
					if (copaSelectedFormation) {
						copaSlots = copaSelectedFormation.slots.map(function(s) {
							return { positionId: s.positionId, x: s.x, y: s.y, player: null, isCaptain: false };
						});
					} else { copaSlots = []; }
					renderPitch(); updateBudget();
				});

				$('copa-reset-btn').addEventListener('click', function() {
					copaSlots.forEach(function(s) { s.player = null; s.isCaptain = false; });
					renderPitch(); updateBudget();
				});

				$('bygg-picker-close').addEventListener('click', closePicker);
				$('bygg-picker-overlay').addEventListener('click', function(e) { if (e.target === this) closePicker(); });
				$('bygg-picker-search-input').addEventListener('input', renderPickerList);

				document.querySelectorAll('.bygg-picker-sort').forEach(function(btn) {
					btn.addEventListener('click', function() {
						var key = btn.getAttribute('data-sort');
						if (copaPickerSort.key === key) copaPickerSort.dir *= -1;
						else { copaPickerSort.key = key; copaPickerSort.dir = -1; }
						document.querySelectorAll('.bygg-picker-sort').forEach(function(b) { b.classList.remove('active'); });
						btn.classList.add('active');
						renderPickerList();
					});
				});

				window.initCopaBuilder = initBuilder;
			})();

			// ---- ADMIN PANEL ----
			(function() {
				var adminPin = '';

				function $(id) { return document.getElementById(id); }

				async function unlockAdmin() {
					var pin = $('admin-pin-input').value.trim();
					var errEl = $('admin-error');
					errEl.textContent = '';
					if (!pin) { errEl.textContent = 'Ange PIN'; return; }
					try {
						var res = await fetch('/api/fantasy/admin/verify', {
							method: 'POST', headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ pin: pin }),
						});
						var data = await res.json();
						if (!res.ok) { errEl.textContent = data.error || 'Fel PIN'; return; }
						adminPin = pin;
						$('admin-gate').style.display = 'none';
						$('admin-panel').style.display = '';
						loadAdminData();
					} catch (e) { errEl.textContent = 'Natverksfel'; }
				}

				async function loadAdminData() {
					// Load config
					try {
						var res = await fetch('/api/fantasy/admin/config');
						if (res.ok) {
							var cfg = await res.json();
							$('admin-league-name').value = cfg.leagueName || '';
							$('admin-budget').value = (cfg.startingBudget || 50000000) / 1000000;
							$('admin-transfer-fee').value = cfg.transferFeePercent != null ? cfg.transferFeePercent : 1;
							$('admin-bank-interest').value = cfg.bankInterestPercent != null ? cfg.bankInterestPercent : 1;
							$('admin-max-per-club').value = cfg.maxPlayersPerClub || 4;
							$('admin-entry-fee').value = cfg.entryFee || 300;
							$('admin-game-id').value = cfg.currentGameId || '731';
							$('admin-reg-open').checked = cfg.registrationOpen !== false;
							$('admin-captain-positive').checked = cfg.captainBonusOnlyPositive !== false;
						}
					} catch {}

					// Load teams
					try {
						var res = await fetch('/api/fantasy/admin/teams?pin=' + encodeURIComponent(adminPin));
						if (res.ok) {
							var teams = await res.json();
							renderAdminTeams(teams);
						}
					} catch {}
				}

				function renderAdminTeams(teams) {
					var el = $('admin-teams-list');
					if (!teams.length) { el.innerHTML = '<div style="color:var(--muted);font-size:0.85rem">Inga lag registrerade annu.</div>'; return; }
					el.innerHTML = teams.map(function(t) {
						var statusCls = t.status || 'pending';
						var actions = '';
						if (statusCls === 'pending') {
							actions = '<div class="admin-team-actions">' +
								'<button class="admin-action-btn approve" data-team="' + t.teamId + '" data-action="approved">Godkann</button>' +
								'<button class="admin-action-btn reject" data-team="' + t.teamId + '" data-action="rejected">Neka</button>' +
								'</div>';
						} else {
							actions = '<span class="admin-team-status ' + statusCls + '">' +
								(statusCls === 'approved' ? 'Godkand' : 'Nekad') + '</span>';
						}
						return '<div class="admin-team-row">' +
							'<div class="admin-team-info"><div class="admin-team-name">' + escapeHtml(t.teamName) + '</div>' +
							'<div class="admin-team-meta">' + t.playerCount + ' spelare \u00b7 ' + new Date(t.createdAt).toLocaleDateString('sv-SE') + '</div></div>' +
							actions + '</div>';
					}).join('');

					el.querySelectorAll('.admin-action-btn').forEach(function(btn) {
						btn.addEventListener('click', async function() {
							var teamId = btn.getAttribute('data-team');
							var action = btn.getAttribute('data-action');
							try {
								var res = await fetch('/api/fantasy/admin/approve', {
									method: 'POST', headers: { 'Content-Type': 'application/json' },
									body: JSON.stringify({ pin: adminPin, teamId: teamId, status: action }),
								});
								if (res.ok) loadAdminData();
							} catch {}
						});
					});
				}

				async function saveConfig() {
					var status = $('admin-config-status');
					status.textContent = 'Sparar...'; status.className = 'bygg-save-status';
					var config = {
						leagueName: $('admin-league-name').value,
						startingBudget: parseFloat($('admin-budget').value) * 1000000,
						transferFeePercent: parseFloat($('admin-transfer-fee').value),
						bankInterestPercent: parseFloat($('admin-bank-interest').value),
						maxPlayersPerClub: parseInt($('admin-max-per-club').value),
						entryFee: parseInt($('admin-entry-fee').value),
						currentGameId: $('admin-game-id').value,
						registrationOpen: $('admin-reg-open').checked,
						captainBonusOnlyPositive: $('admin-captain-positive').checked,
					};
					try {
						var res = await fetch('/api/fantasy/admin/config', {
							method: 'POST', headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ pin: adminPin, config: config }),
						});
						if (res.ok) { status.textContent = 'Sparat!'; status.className = 'bygg-save-status success'; }
						else { var d = await res.json(); status.textContent = d.error || 'Fel'; status.className = 'bygg-save-status error'; }
					} catch { status.textContent = 'Natverksfel'; status.className = 'bygg-save-status error'; }
				}

				$('admin-unlock-btn').addEventListener('click', unlockAdmin);
				$('admin-pin-input').addEventListener('keydown', function(e) { if (e.key === 'Enter') unlockAdmin(); });
				$('admin-save-config').addEventListener('click', saveConfig);

				window.initAdmin = function() {
					if (adminPin) loadAdminData(); // refresh data when switching to admin tab
				};
			})();

			// ---- LIGA STANDINGS ----
			var standingsData = [];

			async function loadStandings() {
				var container = document.getElementById('liga-standings');
				try {
					var res = await fetch('/api/fantasy/league/standings');
					if (!res.ok) throw new Error('API error');
					var data = await res.json();
					standingsData = data.standings || data || [];

					if (!standingsData.length) {
						container.innerHTML = '<div class="leaderboard-loading">Inga lag har registrerats ännu.</div>';
						return;
					}

					var html = standingsData.map(function(t, i) {
						var pos = i + 1;
						var posClass = pos <= 3 ? ' top3' : '';
						var totalStr = t.totalGrowth ? (t.totalGrowth / 1000000).toFixed(2) + 'M' : '--';
						var lastRound = t.rounds && t.rounds.length > 0 ? t.rounds[t.rounds.length - 1] : null;
						var lastStr = lastRound ? (lastRound.total / 1000000).toFixed(2) + 'M' : '';
						var lastClass = lastRound && lastRound.total > 0 ? 'pos' : lastRound && lastRound.total < 0 ? 'neg' : '';
						return '<div class="liga-team-row" data-team-idx="' + i + '">' +
							'<span class="liga-pos' + posClass + '">' + pos + '</span>' +
							'<div class="liga-team-info"><span class="liga-team-name">' + escapeHtml(t.teamName || '') + '</span>' +
							(lastStr ? '<span class="liga-team-last ' + lastClass + '">Senaste: ' + lastStr + '</span>' : '') + '</div>' +
							'<span class="liga-team-pts">' + totalStr + '</span>' +
							'</div>' +
							'<div class="liga-team-detail" id="liga-detail-' + i + '"></div>';
					}).join('');

					container.innerHTML = html;

					// Bind row clicks
					container.querySelectorAll('.liga-team-row').forEach(function(row) {
						row.addEventListener('click', function() {
							var idx = parseInt(row.getAttribute('data-team-idx'));
							toggleTeamDetail(idx);
						});
					});
				} catch (e) {
					container.innerHTML = '<div class="leaderboard-loading">Kunde inte ladda tabell.</div>';
				}
			}

			async function toggleTeamDetail(idx) {
				var detail = document.getElementById('liga-detail-' + idx);
				if (!detail) return;

				if (detail.classList.contains('open')) {
					detail.classList.remove('open');
					detail.innerHTML = '';
					return;
				}

				document.querySelectorAll('.liga-team-detail.open').forEach(function(d) {
					d.classList.remove('open'); d.innerHTML = '';
				});

				var team = standingsData[idx];
				if (!team || !team.players || team.players.length === 0) {
					detail.classList.add('open');
					detail.innerHTML = '<div style="padding:16px;color:var(--muted);font-size:0.85rem">Laget har inte valt spelare ännu.</div>';
					return;
				}

				var sections = [];

				// ---- Round history with bars ----
				if (team.rounds && team.rounds.length > 0) {
					var maxAbs = 0;
					team.rounds.forEach(function(r) { maxAbs = Math.max(maxAbs, Math.abs(r.total)); });

					var cumulative = 0;
					var barsHtml = team.rounds.map(function(r) {
						cumulative += r.total;
						var pct = maxAbs > 0 ? Math.abs(r.total) / maxAbs * 100 : 0;
						var isPos = r.total >= 0;
						var barColor = isPos ? '#22c55e' : '#ef4444';
						var totalStr = (r.total / 1e6).toFixed(2);
						var cumStr = (cumulative / 1e6).toFixed(2);
						var capStr = r.captainBonus > 0 ? ' (C: +' + (r.captainBonus / 1e6).toFixed(2) + ')' : '';
						return '<div class="detail-round-row">' +
							'<span class="detail-round-num">R' + r.round + '</span>' +
							'<div class="detail-round-bar-wrap">' +
								'<div class="detail-round-bar" style="width:' + pct + '%;background:' + barColor + '"></div>' +
							'</div>' +
							'<span class="detail-round-val ' + (isPos ? 'pos' : 'neg') + '">' + (isPos ? '+' : '') + totalStr + 'M</span>' +
							'</div>';
					}).join('');

					var totalStr = (team.totalGrowth / 1e6).toFixed(2);
					sections.push(
						'<div class="detail-section">' +
						'<div class="detail-section-title">Omgångar</div>' +
						barsHtml +
						'<div class="detail-round-row" style="margin-top:6px;padding-top:6px;border-top:1px solid rgba(255,255,255,0.08)">' +
							'<span class="detail-round-num" style="font-weight:600">Tot</span>' +
							'<div class="detail-round-bar-wrap"></div>' +
							'<span class="detail-round-val" style="color:var(--celeste);font-weight:600">' + totalStr + 'M</span>' +
						'</div>' +
						'</div>'
					);
				}

				// ---- Pitch ----
				if (!playersLoaded) await loadPlayers();
				var ruleset = await getRuleset();
				var formation = null;
				if (ruleset && ruleset.formations && team.formationId) {
					formation = ruleset.formations.find(function(f) { return f.id === team.formationId; });
				}

				var posNames = { 6: 'MV', 7: 'Back', 8: 'Mitt', 9: 'Anf' };
				var posCls = { 6: 'mv', 7: '', 8: '', 9: 'anf' };

				if (formation) {
					var byPos = {};
					team.players.forEach(function(tp) {
						var pd = allPlayers.find(function(p) { return p.playerId === tp.playerId; });
						if (!pd) return;
						if (!byPos[pd.position]) byPos[pd.position] = [];
						byPos[pd.position].push({ data: pd, isCaptain: tp.isCaptain });
					});

					var slotsByPos = {};
					formation.slots.forEach(function(s) {
						var pid = s.positionId;
						if (!slotsByPos[pid]) slotsByPos[pid] = [];
						slotsByPos[pid].push(s);
					});
					for (var p in slotsByPos) slotsByPos[p].sort(function(a, b) { return a.x - b.x; });

					var playersHtml = '';
					for (var pos in byPos) {
						var posPlayers = byPos[pos];
						var posSlots = slotsByPos[pos] || [];
						for (var j = 0; j < posPlayers.length; j++) {
							var slot = posSlots[j] || posSlots[posSlots.length - 1];
							if (!slot) continue;
							var pd = posPlayers[j].data;
							var isCap = posPlayers[j].isCaptain;
							var left = 10 + (slot.x / 100) * 80;
							var top = 6 + ((100 - slot.y) / 100) * 88;
							var cls = posCls[pd.position] || '';
							var lastName = pd.name.split(' ').slice(-1)[0];
							var capBadge = isCap ? '<div class="bygg-slot-captain">C</div>' : '';
							playersHtml += '<div class="pitch-player" style="left:' + left + '%;top:' + top + '%">' +
								capBadge +
								'<div class="pitch-dot ' + cls + (isCap ? ' captain' : '') + '">' + buildPlayerAvatar(pd.skinColor, pd.hairColor) + '</div>' +
								'<div class="pitch-name">' + escapeHtml(lastName) + '</div></div>';
						}
					}

					sections.push(
						'<div class="detail-section">' +
						'<div class="detail-section-title">Uppställning</div>' +
						'<div class="pitch">' +
						'<div class="pitch-outline"></div><div class="pitch-lines"></div>' +
						'<div class="pitch-box-top"></div><div class="pitch-box-bottom"></div>' +
						playersHtml + '</div></div>'
					);
				} else {
					var listHtml = team.players.map(function(tp) {
						var pd = allPlayers.find(function(p) { return p.playerId === tp.playerId; });
						if (!pd) return '';
						var cap = tp.isCaptain ? ' <span style="color:var(--yellow)">C</span>' : '';
						return '<div style="padding:4px 0;font-size:0.85rem">' + escapeHtml(pd.name) + cap +
							' <span style="color:var(--muted);font-size:0.75rem">' + (posNames[pd.position] || '') + '</span></div>';
					}).join('');
					sections.push('<div class="detail-section"><div class="detail-section-title">Spelare</div>' + listHtml + '</div>');
				}

				detail.innerHTML = '<div class="detail-content">' + sections.join('') + '</div>';
				detail.classList.add('open');
			}

			// ---- INIT ON PAGE LOAD ----
			(async function() {
				// Check session
				var session = await checkSession();
				if (session && session.authenticated) {
					var status = session.status || 'approved';
					if (status === 'approved') {
						currentUser = session;
						document.getElementById('auth-guest').style.display = 'none';
						document.getElementById('auth-user').style.display = '';
						document.getElementById('auth-user-name').textContent = session.teamName;
						showMittlagNav();
						if (window.initCopaBuilder) window.initCopaBuilder(session);
					}
				}

			})();
		</script>
	</body>
</html>
